{
  "ci": {
    "collect": {
      "startServerCommand": "npm run preview -- --host 127.0.0.1 --port 4321",
      "url": [
        "http://127.0.0.1:4321/",
        "http://127.0.0.1:4321/work/",
        "http://127.0.0.1:4321/research/",
        "http://127.0.0.1:4321/about/",
        "http://127.0.0.1:4321/fr/",
        "http://127.0.0.1:4321/fr/recherche/"
      ],
      "numberOfRuns": 2,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --headless=new"
      }
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": "^http://127\\.0\\.0\\.1:4321/(fr/)?$",
          "assertions": {
            "categories:performance":    ["error", { "minScore": 0.90 }],
            "categories:accessibility":  ["error", { "minScore": 1.00 }],
            "categories:best-practices": ["error", { "minScore": 0.95 }],
            "categories:seo":            ["error", { "minScore": 1.00 }]
          }
        },
        {
          "matchingUrlPattern": "^http://127\\.0\\.0\\.1:4321/(work|research|about|fr/recherche)/$",
          "assertions": {
            "categories:performance":    ["error", { "minScore": 0.95 }],
            "categories:accessibility":  ["error", { "minScore": 1.00 }],
            "categories:best-practices": ["error", { "minScore": 0.95 }],
            "categories:seo":            ["error", { "minScore": 1.00 }]
          }
        }
      ]
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
