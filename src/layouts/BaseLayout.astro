---
/**
 * BaseLayout.astro — the site shell.
 * Zero JS. Plain MPA navigation. Dark-mode-first palette.
 */
import '@/styles/global.css';
import '@fontsource/inter/latin-400.css';
import '@fontsource/inter/latin-500.css';
import '@fontsource/inter/latin-600.css';
import '@fontsource/jetbrains-mono/latin-400.css';
import '@fontsource/jetbrains-mono/latin-500.css';
import { htmlLang, ogLocale, ui, siblingUrl, type Locale } from '@/i18n/strings';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';

export interface Props {
  locale: Locale;
  title: string;
  description: string;
  /** Path under the locale root. e.g. "work/", "research/", "", "about/" */
  pathKey?: string;
  /** og:type — "website" default, "article" for posts. */
  ogType?: 'website' | 'article';
  /** Per-page canonical override (absolute URL). */
  canonical?: string;
  /** Whether to inject the Person JSON-LD (home only). */
  personSchema?: boolean;
}

const {
  locale,
  title,
  description,
  pathKey = '',
  ogType = 'website',
  personSchema = false,
} = Astro.props;

const t = ui[locale];
const site = Astro.site?.href.replace(/\/$/, '') ?? '';
const currentUrl = new URL(Astro.url.pathname, Astro.site || 'http://localhost').href;

// Sibling-locale path for hreflang / language switch
const siblingPath = siblingUrl(locale, pathKey);

const ogImage = `${site}/og-default.svg`;

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Cyrille Tabe',
  url: site + '/',
  jobTitle: 'Robotics Software Engineer',
  worksFor: [
    { '@type': 'Organization', name: 'Noovelia' },
    { '@type': 'Organization', name: 'Odu Technologie' },
  ],
  alumniOf: { '@type': 'CollegeOrUniversity', name: 'Polytechnique Montréal' },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Montréal',
    addressRegion: 'QC',
    addressCountry: 'CA',
  },
  knowsLanguage: ['en', 'fr'],
  email: 'mailto:cyrilletabepro@gmail.com',
};
---

<!doctype html>
<html lang={htmlLang[locale]} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!--
      Content-Security-Policy. Defaults tight. `unsafe-inline` on
      script-src is required because Astro's `client:visible` island
      hydration uses a small inline bootstrap. The site is static and
      accepts no user input, so the inline-script surface is limited
      to code shipped by the build. `'unsafe-inline'` on style-src
      covers Astro's scoped component styles. `blob:` is needed on
      worker-src only if we add workers (we don't).
    -->
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self' mailto:; upgrade-insecure-requests"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={currentUrl} />

    <!-- hreflang alternates -->
    <link
      rel="alternate"
      hreflang={locale === 'en' ? 'fr' : 'en'}
      href={`${site}${siblingPath}`}
    />
    <link rel="alternate" hreflang="x-default" href={`${site}/${pathKey}`} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale[locale]} />
    <meta
      property="og:locale:alternate"
      content={locale === 'en' ? 'fr_CA' : 'en_US'}
    />
    <meta property="og:site_name" content="Cyrille Tabe" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {personSchema && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(personLd)} />
    )}
  </head>
  <body>
    <a class="skip-link" href="#main">{t.skipToMain}</a>

    <header class="site-header">
      <Nav locale={locale} pathKey={pathKey} />
    </header>

    <main id="main" tabindex="-1">
      <slot />
    </main>

    <Footer locale={locale} pathKey={pathKey} />

    <style>
      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        padding-block: var(--space-3);
        background: var(--bg);
        border-bottom: 1px solid transparent;
      }
      /* Thin border only when the page has scrolled — approximated via
         a border that blends with the bg until content slides under it.
         Pure CSS, no JS. */
      @supports (border-bottom: 1px solid var(--surface-2)) {
        .site-header { border-bottom-color: var(--surface-2); }
      }
    </style>
  </body>
</html>
