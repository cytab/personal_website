---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { pageMeta } from '@/i18n/strings';
import {
  hero,
  orientation,
  projects,
} from '@/content/copy';
import RobotArmIsland from '@/components/RobotArm/RobotArmIsland.astro';

const locale = 'en' as const;
const meta = pageMeta[locale].home;
const h = hero[locale];
const o = orientation[locale];

// Featured trio — flagship projects on the home page.
const featuredSlugs = ['robotclaw', 'noovelia-lattice', 'odu-slam'] as const;
---

<BaseLayout
  locale={locale}
  title={meta.title}
  description={meta.description}
  pathKey=""
  personSchema
>
  <div class="page">
    <section class="hero" aria-label="Hero">
      <div class="hero__stage">
        <RobotArmIsland locale={locale} />
      </div>

      <div class="hero__text">
        <p class="hero__eyebrow">{h.eyebrow}</p>
        <h1 class="hero__name">Cyrille Tabe</h1>
        <p class="hero__role">Robotics Software Engineer · Montréal</p>
        <p class="hero__headline">{h.text}</p>
        <div class="hero__ctas">
          <a class="hero__cta" href="/work/">View work →</a>
          <a class="hero__cta" href="/research/">Research interests →</a>
        </div>
      </div>
    </section>

    <section class="intro" aria-labelledby="intro-title">
      <h2 id="intro-title" class="sr-only">Orientation</h2>
      <p class="prose t-reading">{o.text}</p>
    </section>

    <section class="featured" aria-labelledby="featured-title">
      <h2 id="featured-title" class="section-title">Featured work</h2>
      <ul class="featured__list">
        {featuredSlugs.map((slug) => {
          const p = projects[slug];
          const l = p[locale];
          return (
            <li class="featured__item">
              <a class="featured__link" href={`/work/#${p.slug}`}>
                <h3 class="featured__title">{l.title}</h3>
                <p class="featured__body">{l.body}</p>
              </a>
            </li>
          );
        })}
      </ul>
    </section>

    <section class="elsewhere" aria-label="More">
      <p class="prose">
        More in <a href="/work/">Work</a>, <a href="/research/">Research</a>, or <a href="mailto:cyrilletabepro@gmail.com?subject=From%20the%20site">write to me</a>.
      </p>
    </section>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 1040px;
    margin-inline: auto;
    padding: var(--space-5) 1rem var(--space-7);
  }
  @media (min-width: 768px) {
    .page { padding-inline: 2rem; }
  }

  .hero {
    padding-block: var(--space-4);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    align-items: center;
  }
  @media (min-width: 900px) {
    .hero {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
      gap: var(--space-6);
    }
  }

  .hero__stage {
    min-width: 0;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .hero__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    text-transform: uppercase;
    color: var(--ink-muted);
    margin: 0;
  }
  .hero__name {
    font-family: var(--font-body);
    font-size: clamp(1.75rem, 4.5vw, 2.75rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: var(--fw-semibold);
    color: var(--ink);
    margin: 0;
  }
  .hero__role {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--tr-mono);
    color: var(--primary);
    margin: 0;
  }
  .hero__headline {
    font-family: var(--font-body);
    font-size: clamp(1.0625rem, 2.2vw, 1.25rem);
    line-height: 1.45;
    color: var(--ink);
    max-width: 42ch;
    margin: 0;
  }
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }
  .hero__cta {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--tr-mono);
    color: var(--primary);
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--surface-2);
    border-radius: var(--radius-sm);
    transition: border-color 120ms ease, color 120ms ease;
  }
  .hero__cta:hover,
  .hero__cta:focus-visible {
    border-color: var(--primary);
    color: var(--ink);
  }

  .intro {
    padding-block: var(--space-5) var(--space-4);
    border-top: 1px solid var(--surface-2);
    margin-top: var(--space-5);
  }

  .featured {
    padding-block: var(--space-5);
  }
  .section-title {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--tr-mono);
    text-transform: uppercase;
    color: var(--ink-muted);
    font-weight: var(--fw-medium);
    margin-bottom: var(--space-3);
  }
  .featured__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .featured__item {
    border-top: 1px solid var(--surface-2);
    padding-top: var(--space-3);
  }
  .featured__link {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .featured__title {
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: var(--fw-semibold);
    color: var(--ink);
    margin-bottom: var(--space-2);
    transition: color 120ms ease;
  }
  .featured__link:hover .featured__title,
  .featured__link:focus-visible .featured__title {
    color: var(--primary);
  }
  .featured__body {
    color: var(--ink-muted);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    margin: 0;
  }

  .elsewhere {
    padding-block: var(--space-5) var(--space-3);
  }
  .elsewhere a {
    color: var(--primary);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--primary) 40%, transparent);
  }
  .elsewhere a:hover,
  .elsewhere a:focus-visible {
    text-decoration-color: var(--primary);
  }
</style>
