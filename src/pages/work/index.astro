---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { pageMeta } from '@/i18n/strings';
import { projects, projectOrder, academicProjects } from '@/content/copy';
import WorkGlyph from '@/components/WorkGlyph.astro';

const locale = 'en' as const;
const meta = pageMeta[locale].work;
---

<BaseLayout locale={locale} title={meta.title} description={meta.description} pathKey="work/">
  <div class="page">
    <header class="page-header">
      <h1 class="page-title">Work</h1>
      <p class="prose t-reading">
        Personal projects. One flagship I'm building and three academic projects that shipped. The rest of the story — Noovelia, Odu Technologie, Kinova, E-SMART — lives on <a href="/about/#professional-experience">About</a> as professional experience.
      </p>
    </header>

    <div class="work">
      {projectOrder.map((slug) => {
        const p = projects[slug];
        const l = p[locale];
        return (
          <section id={p.slug} class="work__entry reveal-up project-card" aria-labelledby={`${p.slug}-title`}>
            <div class="work__grid">
              <div class="work__main">
                <header class="work__header">
                  <h2 id={`${p.slug}-title`} class="work__title">{l.title}</h2>
                  <p class="work__status">{l.status}</p>
                </header>
                <p class="prose t-reading">{l.bodyLong}</p>
                <ul class="work__tech" aria-label="Tech">
                  {p.tech.map((item) => <li>{item}</li>)}
                </ul>
              </div>
              <aside class="work__glyph" aria-hidden="true">
                <WorkGlyph slug={p.slug as 'robotclaw'} />
              </aside>
            </div>
          </section>
        );
      })}
    </div>

    <section class="academic reveal-up" aria-labelledby="academic-title">
      <h2 id="academic-title" class="academic__title">Academic projects</h2>
      <ul class="academic__list">
        {academicProjects.map((a) => (
          <li id={a.slug} class="academic__item project-card">
            <div class="academic__row">
              <h3 class="academic__name">{a.en.title}</h3>
              <span class="academic__date">{a.date.en}</span>
            </div>
            <p class="academic__tech">{a.tech.join(' · ')}</p>
            <p class="academic__summary">{a.en.summary}</p>
          </li>
        ))}
      </ul>
      <p class="academic__closing prose">
        More on these on request — or browse the public repos at <a href="https://github.com/cytab">github.com/cytab</a>.
      </p>
    </section>
  </div>
</BaseLayout>

<!-- Project-card tilt on cursor hover. ~400 B gzipped. -->
<script is:inline>
  (function () {
    if (window.matchMedia('(hover: none)').matches) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var cards = document.querySelectorAll('.project-card');
    cards.forEach(function (card) {
      var pending = false, lastX = 0, lastY = 0;
      function apply() {
        card.style.setProperty('--tilt-x', lastX.toFixed(2) + 'deg');
        card.style.setProperty('--tilt-y', lastY.toFixed(2) + 'deg');
        pending = false;
      }
      card.addEventListener('mousemove', function (e) {
        var r = card.getBoundingClientRect();
        var px = (e.clientX - r.left) / r.width;   // 0..1
        var py = (e.clientY - r.top) / r.height;   // 0..1
        // Map 0..1 → -1..1, scale to max 4°.
        lastY = (px - 0.5) * 2 * 4;
        lastX = -(py - 0.5) * 2 * 4;
        if (!pending) { requestAnimationFrame(apply); pending = true; }
      });
      card.addEventListener('mouseleave', function () {
        lastX = 0; lastY = 0;
        if (!pending) { requestAnimationFrame(apply); pending = true; }
      });
    });
  })();
</script>

<style>
  .page {
    max-width: 960px;
    margin-inline: auto;
    padding: var(--space-5) 1rem var(--space-7);
  }
  @media (min-width: 768px) {
    .page { padding-inline: 2rem; }
  }

  .page-header { padding-block: var(--space-4) var(--space-5); }
  .page-title {
    font-family: var(--font-body);
    font-size: 2rem;
    font-weight: var(--fw-semibold);
    letter-spacing: -0.015em;
    color: var(--ink);
    margin-bottom: var(--space-3);
  }
  .page-header a {
    color: var(--primary);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--primary) 40%, transparent);
  }
  .page-header a:hover,
  .page-header a:focus-visible {
    text-decoration-color: var(--primary);
  }

  .work__entry {
    padding-block: var(--space-5);
    border-top: 1px solid var(--surface-2);
    scroll-margin-top: 4rem;
  }
  .work__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
  }
  @media (min-width: 768px) {
    .work__grid {
      grid-template-columns: minmax(0, 1fr) 120px;
      gap: var(--space-4);
      align-items: start;
    }
  }
  .work__main { min-width: 0; }
  .work__glyph {
    display: flex;
    justify-content: flex-start;
    padding: var(--space-2);
    border: 1px solid var(--surface-2);
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--surface-1) 50%, transparent);
  }
  @media (min-width: 768px) {
    .work__glyph { order: 2; align-self: start; position: sticky; top: 4.5rem; }
  }
  .work__header {
    margin-bottom: var(--space-3);
  }
  .work__title {
    font-family: var(--font-body);
    font-size: 1.5rem;
    font-weight: var(--fw-semibold);
    color: var(--ink);
    margin-bottom: var(--space-1);
  }
  .work__status {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    text-transform: uppercase;
    color: var(--ink-muted);
    margin: 0;
  }
  .work__tech {
    list-style: none;
    padding: 0;
    margin: var(--space-4) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    color: var(--ink-muted);
  }
  .work__tech li {
    padding: 2px var(--space-2);
    border: 1px solid var(--surface-2);
    border-radius: var(--radius-sm);
  }

  /* Academic projects — text-only, tighter layout */
  .academic {
    padding-block: var(--space-5);
    border-top: 1px solid var(--surface-2);
  }
  .academic__title {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--tr-mono);
    text-transform: uppercase;
    color: var(--ink-muted);
    font-weight: var(--fw-medium);
    margin-bottom: var(--space-4);
  }
  .academic__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .academic__item {
    padding-top: var(--space-3);
    border-top: 1px solid var(--surface-2);
    scroll-margin-top: 4rem;
  }
  .academic__item:first-child {
    border-top: 0;
    padding-top: 0;
  }
  .academic__row {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-3);
  }
  .academic__name {
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: var(--fw-semibold);
    color: var(--ink);
    margin: 0;
  }
  .academic__date {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    color: var(--ink-muted);
    text-align: right;
  }
  .academic__tech {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    color: var(--ink-muted);
    margin: var(--space-1) 0 var(--space-2) 0;
  }
  .academic__summary {
    color: var(--ink);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    margin: 0;
  }
  .academic__closing {
    margin-top: var(--space-5);
    color: var(--ink-muted);
  }
  .academic__closing a {
    color: var(--primary);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--primary) 40%, transparent);
  }
  .academic__closing a:hover,
  .academic__closing a:focus-visible {
    text-decoration-color: var(--primary);
  }

  /* Tilt-on-hover for project cards. CSS vars updated by inline JS.
     Disabled under reduced motion + coarse pointer. */
  .project-card {
    transform: perspective(800px) rotateX(var(--tilt-x, 0deg)) rotateY(var(--tilt-y, 0deg));
    transform-style: preserve-3d;
    transition: transform 300ms var(--ease-default);
    will-change: transform;
  }
  @media (hover: none), (prefers-reduced-motion: reduce) {
    .project-card { transform: none !important; transition: none; }
  }
</style>
