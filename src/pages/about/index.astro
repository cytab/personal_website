---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { pageMeta, ui } from '@/i18n/strings';
import { cv } from '@/content/copy';
import AboutSignature from '@/components/AboutSignature.astro';

const locale = 'en' as const;
const meta = pageMeta[locale].about;
const c = cv[locale];
const uit = ui[locale];
---

<BaseLayout locale={locale} title={meta.title} description={meta.description} pathKey="about/">
  <div class="page">
    <header class="cv-header">
      <div class="cv-header__row">
        <div class="cv-header__sig"><AboutSignature /></div>
        <div class="cv-header__text">
          <h1 class="cv-name">{c.name}</h1>
          <p class="cv-role">{c.role}</p>
        </div>
      </div>
      <ul class="cv-contact" aria-label="Contact">
        <li>{c.contact.phone}</li>
        <li>
          <a href={`mailto:${c.contact.email}`}>{c.contact.email}</a>
          <button
            class="copy-email"
            type="button"
            data-copy-email={c.contact.email}
            data-copy-toast={uit.copy.toast}
            data-copy-failed={uit.copy.failed}
            aria-label={uit.copy.label}
            title={uit.copy.label}
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <rect x="9" y="9" width="11" height="11" rx="2"></rect>
              <path d="M5 15V5a2 2 0 0 1 2-2h10"></path>
            </svg>
          </button>
        </li>
        <li><a href={`https://${c.contact.linkedin}`} rel="noopener">{c.contact.linkedin}</a></li>
        <li><a href={`https://${c.contact.github}`} rel="noopener">{c.contact.github}</a></li>
        <li>{c.contact.location}</li>
      </ul>

      <div class="cv-download">
        <a
          class="cv-download__btn"
          href="/cv/cyrille-tabe-cv-en.pdf"
          download
          aria-label="Download CV (PDF)"
        >
          {c.download.label}
        </a>
        <a
          class="cv-download__alt"
          href={`mailto:${c.contact.email}?subject=CV%20request`}
        >
          {c.download.fallback}
        </a>
      </div>
      <p class="cv-download__note">{c.download.note}</p>
    </header>

    <section class="cv-section reveal-up">
      <p class="prose t-reading cv-intro">{c.aboutMe.body}</p>
    </section>

    <section class="cv-section reveal-up" aria-labelledby="now-title">
      <h2 id="now-title" class="cv-section__title">{c.now.heading}</h2>
      <ul class="cv-now">
        {c.now.items.map((item) => (
          <li class="cv-now__item">
            <span class="cv-now__role">{item.role}</span>
            <span class="cv-now__org">{item.org}</span>
            <span class="cv-now__date">{item.date}</span>
          </li>
        ))}
      </ul>
      <p class="cv-now__edu">{c.now.edu}</p>
    </section>

    <section id="skills" class="cv-section reveal-up" aria-labelledby="skills-title">
      <h2 id="skills-title" class="cv-section__title">{c.skills.heading}</h2>
      <dl class="cv-skills">
        <div class="cv-skills__row">
          <dt class="cv-skills__label">{c.skills.coursesLabel}</dt>
          <dd class="cv-skills__val">{c.skills.courses}</dd>
        </div>
        <div class="cv-skills__row">
          <dt class="cv-skills__label">{c.skills.languagesLabel}</dt>
          <dd class="cv-skills__val">
            {c.skills.languages.map((l, i) => (
              <>
                {i > 0 ? ', ' : ''}
                {l.primary ? <strong>{l.name}</strong> : l.name}
              </>
            ))}
          </dd>
        </div>
        <div class="cv-skills__row">
          <dt class="cv-skills__label">{c.skills.frameworksLabel}</dt>
          <dd class="cv-skills__val">
            {c.skills.frameworks.map((f, i) => (
              <>
                {i > 0 ? ', ' : ''}
                {f.primary ? <strong>{f.name}</strong> : f.name}
              </>
            ))}
          </dd>
        </div>
      </dl>
    </section>

    <p class="cv-linkout prose">
      {c.now.linkoutPrefix}
      {' '}<a href="/cv/cyrille-tabe-cv-en.pdf" download>{c.now.linkoutPdfLabel}</a>{c.now.linkoutMid}
      {' '}<a href="/work/">{c.now.linkoutWorkLabel}</a> {c.now.linkoutAnd}
      {' '}<a href="/research/">{c.now.linkoutResearchLabel}</a>{c.now.linkoutSuffix}
    </p>
  </div>
</BaseLayout>

<!-- Copy-email (~350 B gzipped). -->
<script is:inline>
  (function () {
    // Copy email buttons
    document.querySelectorAll('.copy-email').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var email = btn.getAttribute('data-copy-email') || '';
        var tMsg = btn.getAttribute('data-copy-toast') || 'Copied';
        var fMsg = btn.getAttribute('data-copy-failed') || 'Copy failed';
        function showToast(msg) {
          var prev = document.querySelector('.cmdk-toast');
          if (prev) prev.remove();
          var el = document.createElement('div');
          el.className = 'cmdk-toast';
          el.setAttribute('role', 'status');
          el.setAttribute('aria-live', 'polite');
          el.textContent = msg;
          document.body.appendChild(el);
          requestAnimationFrame(function () { el.classList.add('is-visible'); });
          setTimeout(function () {
            el.classList.remove('is-visible');
            setTimeout(function () { el.remove(); }, 300);
          }, 1600);
        }
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(email).then(
            function () {
              btn.classList.add('is-copied');
              setTimeout(function () { btn.classList.remove('is-copied'); }, 1200);
              showToast(tMsg);
            },
            function () { showToast(fMsg); }
          );
        } else {
          showToast(fMsg);
        }
      });
    });

  })();
</script>

<style>
  .page {
    max-width: 820px;
    margin-inline: auto;
    padding: var(--space-5) 1rem var(--space-7);
  }
  @media (min-width: 768px) {
    .page { padding-inline: 2rem; }
  }

  /* ---------- Header ---------- */
  .cv-header {
    padding-block: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--surface-2);
  }
  .cv-header__row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }
  .cv-header__sig {
    flex: 0 0 auto;
    line-height: 0;
  }
  .cv-name {
    font-family: var(--font-body);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: var(--fw-semibold);
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 0 0 var(--space-1) 0;
    line-height: 1.1;
  }
  .cv-role {
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--ink-muted);
    margin: 0;
  }
  .cv-contact {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    color: var(--ink-muted);
    margin: 0 0 var(--space-4) 0;
    line-height: 1.7;
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.15em 0.35em;
    word-break: break-word;
  }
  .cv-contact li {
    display: inline;
  }
  .cv-contact li + li::before {
    content: "·";
    margin-right: 0.35em;
    opacity: 0.6;
  }
  .cv-contact a {
    color: var(--ink-muted);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--ink-muted) 40%, transparent);
  }
  .cv-contact a:hover,
  .cv-contact a:focus-visible {
    color: var(--primary);
    text-decoration-color: var(--primary);
  }

  /* ---------- Download CTA ---------- */
  .cv-download {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }
  .cv-download__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    min-height: 44px;
    min-width: 44px;
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--tr-mono);
    color: var(--primary);
    text-decoration: none;
    border: 1.5px solid var(--primary);
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--primary) 6%, transparent);
    transition: background 120ms ease, color 120ms ease;
  }
  .cv-download__btn:hover,
  .cv-download__btn:focus-visible {
    background: var(--primary);
    color: var(--bg);
  }
  .cv-download__alt {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--tr-mono);
    color: var(--ink-muted);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--ink-muted) 40%, transparent);
  }
  .cv-download__alt:hover,
  .cv-download__alt:focus-visible {
    color: var(--ink);
    text-decoration-color: var(--ink);
  }
  .cv-download__note {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    color: var(--ink-muted);
    margin: 0;
  }

  /* ---------- Section ---------- */
  .cv-section {
    padding-block: var(--space-5);
    border-top: 1px solid var(--surface-2);
    scroll-margin-top: 4rem;
  }
  .cv-section:first-of-type { border-top: 0; }
  .cv-section__title {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--tr-mono);
    text-transform: uppercase;
    color: var(--ink-muted);
    font-weight: var(--fw-medium);
    margin: 0 0 var(--space-4) 0;
  }

  /* ---------- Entry (education / experience / research) ---------- */
  .cv-entries {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin: 0;
  }
  .cv-entry { margin: 0; }
  .cv-entry__row {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-2);
  }
  .cv-entry__title {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    font-weight: var(--fw-semibold);
    color: var(--ink);
    margin: 0;
  }
  .cv-entry__company {
    font-weight: var(--fw-semibold);
    color: var(--ink);
  }
  .cv-entry__role {
    font-weight: var(--fw-regular);
    color: var(--ink-muted);
  }
  .cv-entry__sep {
    color: var(--ink-muted);
  }
  .cv-entry__date {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    color: var(--ink-muted);
    text-align: right;
    margin: 0;
    white-space: nowrap;
  }
  .cv-entry__sub {
    font-size: var(--fs-body);
    color: var(--ink-muted);
    margin: var(--space-1) 0 var(--space-2) 0;
    font-style: italic;
  }
  .cv-bullets {
    list-style: disc;
    padding-left: 1.25rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    color: var(--ink);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
  }
  .cv-bullets li::marker { color: var(--ink-muted); }

  /* ---------- Skills ---------- */
  .cv-skills {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .cv-skills__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-1);
  }
  @media (min-width: 640px) {
    .cv-skills__row {
      grid-template-columns: 10rem 1fr;
      gap: var(--space-3);
      align-items: baseline;
    }
  }
  .cv-skills__label {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    text-transform: uppercase;
    color: var(--ink-muted);
    margin: 0;
  }
  .cv-skills__val {
    margin: 0;
    color: var(--ink);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
  }
  .cv-skills__val strong {
    color: var(--ink);
    font-weight: var(--fw-semibold);
  }

  /* ---------- Intro ---------- */
  .cv-intro {
    margin: 0;
    color: var(--ink);
  }

  /* ---------- Currently ---------- */
  .cv-now {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-3) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .cv-now__item {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.55rem;
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--ink);
  }
  .cv-now__role {
    font-weight: var(--fw-semibold);
    color: var(--ink);
  }
  .cv-now__org {
    color: var(--ink-muted);
    padding-left: 0.35rem;
    border-left: 1px solid color-mix(in srgb, var(--ink-muted) 35%, transparent);
  }
  .cv-now__date {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    color: var(--ink-muted);
    white-space: nowrap;
  }
  .cv-now__edu {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    color: var(--ink-muted);
    margin: 0;
  }

  /* ---------- Link-out ---------- */
  .cv-linkout {
    margin-top: var(--space-5);
    color: var(--ink-muted);
  }
  .cv-linkout a {
    color: var(--primary);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--primary) 40%, transparent);
    transition: text-decoration-color 120ms ease;
  }
  .cv-linkout a:hover,
  .cv-linkout a:focus-visible {
    text-decoration-color: var(--primary);
  }
</style>
