---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { pageMeta, ui } from '@/i18n/strings';
import { cv } from '@/content/copy';
import AboutSignature from '@/components/AboutSignature.astro';

const locale = 'en' as const;
const meta = pageMeta[locale].about;
const c = cv[locale];
const uit = ui[locale];
---

<BaseLayout locale={locale} title={meta.title} description={meta.description} pathKey="about/">
  <div class="page">
    <header class="cv-header">
      <div class="cv-header__row">
        <div class="cv-header__sig"><AboutSignature /></div>
        <div class="cv-header__text">
          <h1 class="cv-name">{c.name}</h1>
          <p class="cv-role">{c.role}</p>
        </div>
      </div>
      <ul class="cv-contact" aria-label="Contact">
        <li>{c.contact.phone}</li>
        <li>
          <a href={`mailto:${c.contact.email}`}>{c.contact.email}</a>
          <button
            class="copy-email"
            type="button"
            data-copy-email={c.contact.email}
            data-copy-toast={uit.copy.toast}
            data-copy-failed={uit.copy.failed}
            aria-label={uit.copy.label}
            title={uit.copy.label}
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <rect x="9" y="9" width="11" height="11" rx="2"></rect>
              <path d="M5 15V5a2 2 0 0 1 2-2h10"></path>
            </svg>
          </button>
        </li>
        <li><a href={`https://${c.contact.linkedin}`} rel="noopener">{c.contact.linkedin}</a></li>
        <li><a href={`https://${c.contact.github}`} rel="noopener">{c.contact.github}</a></li>
        <li>{c.contact.location}</li>
      </ul>

      <div class="cv-download">
        <a
          class="cv-download__btn"
          href="/cv/cyrille-tabe-cv-en.pdf"
          download
          aria-label="Download CV (PDF)"
        >
          {c.download.label}
        </a>
        <a
          class="cv-download__alt"
          href={`mailto:${c.contact.email}?subject=CV%20request`}
        >
          {c.download.fallback}
        </a>
      </div>
      <p class="cv-download__note">{c.download.note}</p>
    </header>

    <section class="cv-section reveal-up" aria-labelledby="edu-title">
      <h2 id="edu-title" class="cv-section__title">{c.education.heading}</h2>
      <div class="cv-entries">
        {c.education.items.map((item) => (
          <article class="cv-entry">
            <div class="cv-entry__row">
              <h3 class="cv-entry__title">{item.title}</h3>
              <p class="cv-entry__date">{item.date}</p>
            </div>
            <p class="cv-entry__sub">{item.institution}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="professional-experience" class="cv-section reveal-up" aria-labelledby="exp-title">
      <h2 id="exp-title" class="cv-section__title">{c.experience.heading}</h2>
      <div class="cv-entries">
        {c.experience.items.map((job) => (
          <article class="cv-entry">
            <div class="cv-entry__row">
              <h3 class="cv-entry__title">
                <span class="cv-entry__company">{job.company}</span>
                {' — '}
                <span class="cv-entry__role">{job.role}</span>
              </h3>
              <p class="cv-entry__date">{job.date}</p>
            </div>
            <p class="cv-entry__sub">{job.location}</p>
            <ul class="cv-bullets">
              {job.bullets.map((b) => <li>{b}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="cv-section reveal-up" aria-labelledby="res-title">
      <h2 id="res-title" class="cv-section__title">{c.research.heading}</h2>
      <div class="cv-entries">
        {c.research.items.map((r) => (
          <article class="cv-entry">
            <div class="cv-entry__row">
              <h3 class="cv-entry__title">{r.title}</h3>
              <p class="cv-entry__date">{r.date}</p>
            </div>
            <p class="cv-entry__sub">{r.institution}</p>
            <ul class="cv-bullets">
              {r.bullets.map((b) => <li>{b}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section id="skills" class="cv-section reveal-up" aria-labelledby="skills-title">
      <h2 id="skills-title" class="cv-section__title">{c.skills.heading}</h2>
      <dl class="cv-skills">
        <div class="cv-skills__row">
          <dt class="cv-skills__label">{c.skills.coursesLabel}</dt>
          <dd class="cv-skills__val">{c.skills.courses}</dd>
        </div>
        <div class="cv-skills__row">
          <dt class="cv-skills__label">{c.skills.languagesLabel}</dt>
          <dd class="cv-skills__val">
            {c.skills.languages.map((l, i) => (
              <>
                {i > 0 ? ', ' : ''}
                {l.primary ? <strong>{l.name}</strong> : l.name}
              </>
            ))}
          </dd>
        </div>
        <div class="cv-skills__row">
          <dt class="cv-skills__label">{c.skills.frameworksLabel}</dt>
          <dd class="cv-skills__val">
            {c.skills.frameworks.map((f, i) => (
              <>
                {i > 0 ? ', ' : ''}
                {f.primary ? <strong>{f.name}</strong> : f.name}
              </>
            ))}
          </dd>
        </div>
      </dl>
    </section>

    <section class="cv-section reveal-up" aria-labelledby="aboutme-title">
      <h2 id="aboutme-title" class="cv-section__title">{c.aboutMe.heading}</h2>
      <p class="prose t-reading">{c.aboutMe.body}</p>
    </section>

    <p class="contact prose">
      Contact: <a href={`mailto:${c.contact.email}`}>{c.contact.email}</a>
      <button
        class="copy-email"
        type="button"
        data-copy-email={c.contact.email}
        data-copy-toast={uit.copy.toast}
        data-copy-failed={uit.copy.failed}
        aria-label={uit.copy.label}
        title={uit.copy.label}
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <rect x="9" y="9" width="11" height="11" rx="2"></rect>
          <path d="M5 15V5a2 2 0 0 1 2-2h10"></path>
        </svg>
      </button>
    </p>
  </div>
</BaseLayout>

<!-- Copy-email + count-up (~700 B gzipped combined). -->
<script is:inline>
  (function () {
    // Copy email buttons
    document.querySelectorAll('.copy-email').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var email = btn.getAttribute('data-copy-email') || '';
        var tMsg = btn.getAttribute('data-copy-toast') || 'Copied';
        var fMsg = btn.getAttribute('data-copy-failed') || 'Copy failed';
        function showToast(msg) {
          var prev = document.querySelector('.cmdk-toast');
          if (prev) prev.remove();
          var el = document.createElement('div');
          el.className = 'cmdk-toast';
          el.setAttribute('role', 'status');
          el.setAttribute('aria-live', 'polite');
          el.textContent = msg;
          document.body.appendChild(el);
          requestAnimationFrame(function () { el.classList.add('is-visible'); });
          setTimeout(function () {
            el.classList.remove('is-visible');
            setTimeout(function () { el.remove(); }, 300);
          }, 1600);
        }
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(email).then(
            function () {
              btn.classList.add('is-copied');
              setTimeout(function () { btn.classList.remove('is-copied'); }, 1200);
              showToast(tMsg);
            },
            function () { showToast(fMsg); }
          );
        } else {
          showToast(fMsg);
        }
      });
    });

    // Count-up animation for CV bullet numbers.
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    // Match: "14%", "14 %", "14 %" with NBSP, "3+" (weeks/semaines), "3+ weeks"
    // We wrap the entire number+optional-suffix as a span we can animate.
    var bullets = document.querySelectorAll('.cv-bullets li');
    bullets.forEach(function (li) {
      if (li.querySelector('.count-up')) return;
      var html = li.innerHTML;
      // Numeric patterns: NN%, NN %, NN %, NN+
      var out = html.replace(/(\d+)( %|\s%|%|\+)/g, function (_m, num, suf) {
        return '<span class="count-up" data-to="' + num + '" data-suffix="' + suf.replace(/"/g, '') + '">' + num + suf + '</span>';
      });
      if (out !== html) li.innerHTML = out;
    });

    var spans = document.querySelectorAll('.count-up');
    if (!spans.length || !('IntersectionObserver' in window)) return;
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (ent) {
        if (!ent.isIntersecting) return;
        var el = ent.target;
        io.unobserve(el);
        var to = parseInt(el.getAttribute('data-to') || '0', 10);
        var suf = el.getAttribute('data-suffix') || '';
        var dur = 900;
        var t0 = performance.now();
        function frame(now) {
          var t = Math.min(1, (now - t0) / dur);
          // ease-out cubic
          var v = 1 - Math.pow(1 - t, 3);
          var n = Math.round(to * v);
          el.textContent = n + suf;
          if (t < 1) requestAnimationFrame(frame);
        }
        requestAnimationFrame(frame);
      });
    }, { threshold: 0.4 });
    spans.forEach(function (s) { io.observe(s); });
  })();
</script>

<style>
  .page {
    max-width: 820px;
    margin-inline: auto;
    padding: var(--space-5) 1rem var(--space-7);
  }
  @media (min-width: 768px) {
    .page { padding-inline: 2rem; }
  }

  /* ---------- Header ---------- */
  .cv-header {
    padding-block: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--surface-2);
  }
  .cv-header__row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }
  .cv-header__sig {
    flex: 0 0 auto;
    line-height: 0;
  }
  .cv-name {
    font-family: var(--font-body);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: var(--fw-semibold);
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 0 0 var(--space-1) 0;
    line-height: 1.1;
  }
  .cv-role {
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--ink-muted);
    margin: 0;
  }
  .cv-contact {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    color: var(--ink-muted);
    margin: 0 0 var(--space-4) 0;
    line-height: 1.7;
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.15em 0.35em;
    word-break: break-word;
  }
  .cv-contact li {
    display: inline;
  }
  .cv-contact li + li::before {
    content: "·";
    margin-right: 0.35em;
    opacity: 0.6;
  }
  .cv-contact a {
    color: var(--ink-muted);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--ink-muted) 40%, transparent);
  }
  .cv-contact a:hover,
  .cv-contact a:focus-visible {
    color: var(--primary);
    text-decoration-color: var(--primary);
  }

  /* ---------- Download CTA ---------- */
  .cv-download {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }
  .cv-download__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    min-height: 44px;
    min-width: 44px;
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--tr-mono);
    color: var(--primary);
    text-decoration: none;
    border: 1.5px solid var(--primary);
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--primary) 6%, transparent);
    transition: background 120ms ease, color 120ms ease;
  }
  .cv-download__btn:hover,
  .cv-download__btn:focus-visible {
    background: var(--primary);
    color: var(--bg);
  }
  .cv-download__alt {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--tr-mono);
    color: var(--ink-muted);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--ink-muted) 40%, transparent);
  }
  .cv-download__alt:hover,
  .cv-download__alt:focus-visible {
    color: var(--ink);
    text-decoration-color: var(--ink);
  }
  .cv-download__note {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    color: var(--ink-muted);
    margin: 0;
  }

  /* ---------- Section ---------- */
  .cv-section {
    padding-block: var(--space-5);
    border-top: 1px solid var(--surface-2);
    scroll-margin-top: 4rem;
  }
  .cv-section:first-of-type { border-top: 0; }
  .cv-section__title {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--tr-mono);
    text-transform: uppercase;
    color: var(--ink-muted);
    font-weight: var(--fw-medium);
    margin: 0 0 var(--space-4) 0;
  }

  /* ---------- Entry (education / experience / research) ---------- */
  .cv-entries {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin: 0;
  }
  .cv-entry { margin: 0; }
  .cv-entry__row {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-2);
  }
  .cv-entry__title {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    font-weight: var(--fw-semibold);
    color: var(--ink);
    margin: 0;
  }
  .cv-entry__company {
    font-weight: var(--fw-semibold);
    color: var(--ink);
  }
  .cv-entry__role {
    font-weight: var(--fw-regular);
    color: var(--ink-muted);
  }
  .cv-entry__sep {
    color: var(--ink-muted);
  }
  .cv-entry__date {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    color: var(--ink-muted);
    text-align: right;
    margin: 0;
    white-space: nowrap;
  }
  .cv-entry__sub {
    font-size: var(--fs-body);
    color: var(--ink-muted);
    margin: var(--space-1) 0 var(--space-2) 0;
    font-style: italic;
  }
  .cv-bullets {
    list-style: disc;
    padding-left: 1.25rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    color: var(--ink);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
  }
  .cv-bullets li::marker { color: var(--ink-muted); }

  /* ---------- Skills ---------- */
  .cv-skills {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .cv-skills__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-1);
  }
  @media (min-width: 640px) {
    .cv-skills__row {
      grid-template-columns: 10rem 1fr;
      gap: var(--space-3);
      align-items: baseline;
    }
  }
  .cv-skills__label {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    text-transform: uppercase;
    color: var(--ink-muted);
    margin: 0;
  }
  .cv-skills__val {
    margin: 0;
    color: var(--ink);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
  }
  .cv-skills__val strong {
    color: var(--ink);
    font-weight: var(--fw-semibold);
  }

  .contact {
    margin-top: var(--space-5);
    color: var(--ink-muted);
  }
  .contact a {
    color: var(--primary);
  }
</style>
