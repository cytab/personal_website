---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { pageMeta, ui } from '@/i18n/strings';

const locale = 'en' as const;
const meta = pageMeta[locale].notFound;
const t = ui[locale];
---

<BaseLayout locale={locale} title={meta.title} description={meta.description} pathKey="">
  <div class="page">
    <section class="notfound">
      <p class="eyebrow">§ 404 / ROUTE NOT IN PLAN</p>
      <h1 class="page-title">{t.notFoundTitle}</h1>
      <p class="prose t-reading">{t.notFoundBody}</p>
      <p class="notfound__back">
        <a href="/">{t.backToStart} →</a>
      </p>
    </section>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 720px;
    margin-inline: auto;
    padding: var(--space-5) 1rem var(--space-8);
  }
  @media (min-width: 768px) {
    .page { padding-inline: 2rem; }
  }
  .notfound {
    padding-block: var(--space-7);
    min-height: 50vh;
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    text-transform: uppercase;
    color: var(--ink-muted);
    margin: 0 0 var(--space-3) 0;
  }
  .page-title {
    font-family: var(--font-body);
    font-size: 2rem;
    font-weight: var(--fw-semibold);
    letter-spacing: -0.015em;
    color: var(--ink);
    margin-bottom: var(--space-3);
  }
  .notfound__back {
    margin-top: var(--space-4);
  }
  .notfound__back a {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--tr-mono);
    color: var(--primary);
  }
</style>
