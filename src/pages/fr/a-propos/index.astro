---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { pageMeta } from '@/i18n/strings';
import { about } from '@/content/copy';

const locale = 'fr' as const;
const meta = pageMeta[locale].about;
const copy = about[locale];
---

<BaseLayout locale={locale} title={meta.title} description={meta.description} pathKey="a-propos/">
  <div class="page">
    <header class="page-header">
      <h1 class="page-title">{copy.title}</h1>
    </header>

    <p class="prose t-reading">{copy.body}</p>

    <aside class="cv-card" aria-labelledby="cv-label">
      <h2 id="cv-label" class="cv-card__label">{copy.cvLabel} — par courriel</h2>
      <p class="cv-card__body prose">{copy.cvBody}</p>
      <a
        class="cv-card__cta"
        href="mailto:cyrilletabe@gmail.com?subject=Demande%20de%20CV"
      >
        {copy.cvCta} &nbsp;→
      </a>
    </aside>

    <p class="contact prose">
      Contact : <a href="mailto:cyrilletabe@gmail.com">cyrilletabe@gmail.com</a>
    </p>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 720px;
    margin-inline: auto;
    padding: var(--space-5) 1rem var(--space-7);
  }
  @media (min-width: 768px) {
    .page { padding-inline: 2rem; }
  }

  .page-header { padding-block: var(--space-4) var(--space-5); }
  .page-title {
    font-family: var(--font-body);
    font-size: 2rem;
    font-weight: var(--fw-semibold);
    letter-spacing: -0.015em;
    color: var(--ink);
  }

  .cv-card {
    margin-top: var(--space-5);
    padding: var(--space-4);
    border: 1px solid var(--surface-2);
    border-radius: var(--radius-md);
    background: var(--surface-1);
  }
  .cv-card__label {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    text-transform: uppercase;
    color: var(--ink-muted);
    margin: 0 0 var(--space-2) 0;
  }
  .cv-card__body { margin: 0 0 var(--space-3) 0; }
  .cv-card__cta {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--tr-mono);
    color: var(--primary);
    text-decoration: none;
    transition: text-decoration-color 120ms ease;
  }
  .cv-card__cta:hover,
  .cv-card__cta:focus-visible {
    text-decoration: underline;
  }

  .contact {
    margin-top: var(--space-5);
    color: var(--ink-muted);
  }
  .contact a {
    color: var(--primary);
  }
</style>
