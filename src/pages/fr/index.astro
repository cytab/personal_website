---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { pageMeta } from '@/i18n/strings';
import {
  hero,
  orientation,
} from '@/content/copy';
import RobotArmIsland from '@/components/RobotArm/RobotArmIsland.astro';

const locale = 'fr' as const;
const meta = pageMeta[locale].home;
const h = hero[locale];
const o = orientation[locale];
---

<BaseLayout
  locale={locale}
  title={meta.title}
  description={meta.description}
  pathKey=""
  personSchema
>
  <div class="scroll-progress" aria-hidden="true"><span class="scroll-progress__bar"></span></div>
  <div class="page">
    <section class="hero" aria-label="Accueil">
      <div class="hero__stage">
        <RobotArmIsland locale={locale} />
      </div>

      <div class="hero__text">
        <p class="hero__eyebrow">{h.eyebrow}</p>
        <h1 class="hero__name">Cyrille Tabe</h1>
        <p class="hero__role">Ingénieur logiciel en robotique · Montréal</p>
        <p class="hero__headline">{h.text}</p>
        <div class="hero__ctas">
          <a class="hero__cta" href="/fr/travaux/">Voir les travaux →</a>
          <a class="hero__cta" href="/fr/recherche/">Intérêts de recherche →</a>
        </div>
      </div>
    </section>

    <section class="intro" aria-labelledby="intro-title">
      <h2 id="intro-title" class="sr-only">Orientation</h2>
      <p class="prose t-reading">{o.text}</p>
    </section>

    <section class="featured" aria-labelledby="featured-title">
      <h2 id="featured-title" class="section-title">Travaux choisis</h2>
      <dl class="featured__split">
        <div class="featured__row">
          <dt class="featured__label">Je construis →</dt>
          <dd class="featured__value">
            <a href="/fr/travaux/#robotclaw">RobotClaw</a> <span class="featured__aside">(projet personnel, bientôt open-source)</span>
          </dd>
        </div>
        <div class="featured__row">
          <dt class="featured__label">Je livre au travail →</dt>
          <dd class="featured__value">
            <a href="/fr/a-propos/#professional-experience">Noovelia</a> <span class="featured__aside">(behavior trees + lattice planner 4D + MPC sur AGV)</span>
          </dd>
        </div>
        <div class="featured__row">
          <dt class="featured__label"></dt>
          <dd class="featured__value">
            <a href="/fr/a-propos/#professional-experience">Odu Technologie</a> <span class="featured__aside">(SLAM + fusion multi-capteurs sur robots de trottoir)</span>
          </dd>
        </div>
      </dl>
      <p class="featured__foot">→ CV complet sur <a href="/fr/a-propos/">À propos</a> · Intérêts de recherche sur <a href="/fr/recherche/">Recherche</a></p>
    </section>

    <section class="elsewhere" aria-label="Ailleurs">
      <p class="prose">
        Plus dans <a href="/fr/travaux/">Travaux</a>, <a href="/fr/recherche/">Recherche</a>, ou <a href="mailto:cyrilletabepro@gmail.com?subject=Depuis%20le%20site">écrivez-moi</a>.
      </p>
    </section>
  </div>
</BaseLayout>

<!--
  Scroll-progress polyfill — ~200 B gzipped. Parity with /.
-->
<script is:inline>
  (function () {
    var el = document.querySelector('.scroll-progress__bar');
    if (!el) return;
    if (typeof CSS !== 'undefined' && CSS.supports && CSS.supports('animation-timeline:scroll()')) {
      return;
    }
    var ticking = false;
    function update() {
      var h = document.documentElement;
      var max = (h.scrollHeight - h.clientHeight) || 1;
      var pct = Math.max(0, Math.min(1, (h.scrollTop || document.body.scrollTop) / max));
      el.style.transform = 'scaleX(' + pct + ')';
      ticking = false;
    }
    function onScroll() {
      if (!ticking) { requestAnimationFrame(update); ticking = true; }
    }
    update();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
  })();
</script>

<style>
  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    z-index: 50;
    pointer-events: none;
    background: transparent;
  }
  .scroll-progress__bar {
    display: block;
    height: 100%;
    width: 100%;
    background: var(--primary);
    transform-origin: left center;
    transform: scaleX(0);
    will-change: transform;
  }
  @supports (animation-timeline: scroll()) {
    .scroll-progress__bar {
      animation: scroll-progress-fill linear both;
      animation-timeline: scroll(root);
    }
    @keyframes scroll-progress-fill {
      to { transform: scaleX(1); }
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-progress__bar { display: none; }
  }

  .page {
    max-width: 1040px;
    margin-inline: auto;
    padding: var(--space-5) 1rem var(--space-7);
  }
  @media (min-width: 768px) {
    .page { padding-inline: 2rem; }
  }

  .hero {
    padding-block: var(--space-4);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    align-items: center;
  }
  @media (min-width: 900px) {
    .hero {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
      gap: var(--space-6);
    }
  }

  .hero__stage { min-width: 0; }

  .hero__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .hero__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    text-transform: uppercase;
    color: var(--ink-muted);
    margin: 0;
  }
  .hero__name {
    font-family: var(--font-body);
    font-size: clamp(1.75rem, 4.5vw, 2.75rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: var(--fw-semibold);
    color: var(--ink);
    margin: 0;
  }
  .hero__role {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--tr-mono);
    color: var(--primary);
    margin: 0;
  }
  .hero__headline {
    font-family: var(--font-body);
    font-size: clamp(1.0625rem, 2.2vw, 1.25rem);
    line-height: 1.45;
    color: var(--ink);
    max-width: 42ch;
    margin: 0;
  }
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }
  .hero__cta {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--tr-mono);
    color: var(--primary);
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--surface-2);
    border-radius: var(--radius-sm);
    transition: border-color 120ms ease, color 120ms ease;
  }
  .hero__cta:hover,
  .hero__cta:focus-visible {
    border-color: var(--primary);
    color: var(--ink);
  }

  .intro {
    padding-block: var(--space-5) var(--space-4);
    border-top: 1px solid var(--surface-2);
    margin-top: var(--space-5);
  }

  .featured {
    padding-block: var(--space-5);
  }
  .section-title {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--tr-mono);
    text-transform: uppercase;
    color: var(--ink-muted);
    font-weight: var(--fw-medium);
    margin-bottom: var(--space-3);
  }
  .featured__split {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .featured__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-1);
    border-top: 1px solid var(--surface-2);
    padding-top: var(--space-3);
  }
  @media (min-width: 720px) {
    .featured__row {
      grid-template-columns: 14rem 1fr;
      gap: var(--space-3);
      align-items: baseline;
    }
  }
  .featured__label {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--tr-mono);
    color: var(--ink-muted);
    margin: 0;
  }
  .featured__value {
    margin: 0;
    color: var(--ink);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
  }
  .featured__value a {
    color: var(--primary);
    font-weight: var(--fw-semibold);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--primary) 40%, transparent);
    transition: text-decoration-color 120ms ease;
  }
  .featured__value a:hover,
  .featured__value a:focus-visible {
    text-decoration-color: var(--primary);
  }
  .featured__aside {
    color: var(--ink-muted);
    font-size: var(--fs-body);
  }
  .featured__foot {
    margin-top: var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--tr-mono);
    color: var(--ink-muted);
  }
  .featured__foot a {
    color: var(--primary);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--primary) 40%, transparent);
  }
  .featured__foot a:hover,
  .featured__foot a:focus-visible {
    text-decoration-color: var(--primary);
  }

  .elsewhere {
    padding-block: var(--space-5) var(--space-3);
  }
  .elsewhere a {
    color: var(--primary);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--primary) 40%, transparent);
  }
  .elsewhere a:hover,
  .elsewhere a:focus-visible {
    text-decoration-color: var(--primary);
  }
</style>
