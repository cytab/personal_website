---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { pageMeta } from '@/i18n/strings';
import { projects, projectOrder } from '@/content/copy';
import WorkGlyph from '@/components/WorkGlyph.astro';

const locale = 'fr' as const;
const meta = pageMeta[locale].work;
---

<BaseLayout locale={locale} title={meta.title} description={meta.description} pathKey="travaux/">
  <div class="page">
    <header class="page-header">
      <h1 class="page-title">Travaux</h1>
      <p class="prose t-reading">
        Cinq systèmes qui existent dans le monde réel. Chacun m'a appris quelque chose qui ne se lit pas.
      </p>
    </header>

    <nav class="toc" aria-label="Projets">
      <ul>
        {projectOrder.map((slug) => (
          <li><a href={`#${slug}`}>{projects[slug][locale].title}</a></li>
        ))}
      </ul>
    </nav>

    <div class="work">
      {projectOrder.map((slug) => {
        const p = projects[slug];
        const l = p[locale];
        return (
          <section id={p.slug} class="work__entry" aria-labelledby={`${p.slug}-title`}>
            <div class="work__grid">
              <div class="work__main">
                <header class="work__header">
                  <h2 id={`${p.slug}-title`} class="work__title">{l.title}</h2>
                  <p class="work__status">{l.status}</p>
                </header>
                <p class="prose t-reading">{l.bodyLong}</p>
                <ul class="work__tech" aria-label="Tech">
                  {p.tech.map((item) => <li>{item}</li>)}
                </ul>
              </div>
              <aside class="work__glyph" aria-hidden="true">
                <WorkGlyph slug={p.slug as any} />
              </aside>
            </div>
          </section>
        );
      })}
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 960px;
    margin-inline: auto;
    padding: var(--space-5) 1rem var(--space-7);
  }
  @media (min-width: 768px) {
    .page { padding-inline: 2rem; }
  }

  .page-header { padding-block: var(--space-4) var(--space-5); }
  .page-title {
    font-family: var(--font-body);
    font-size: 2rem;
    font-weight: var(--fw-semibold);
    letter-spacing: -0.015em;
    color: var(--ink);
    margin-bottom: var(--space-3);
  }

  .toc {
    padding-block: var(--space-3);
    border-block: 1px solid var(--surface-2);
    margin-block: var(--space-3) var(--space-5);
  }
  .toc ul {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-wrap: wrap; gap: var(--space-4);
  }
  .toc a {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--tr-mono);
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 120ms ease;
  }
  .toc a:hover,
  .toc a:focus-visible {
    color: var(--ink);
  }

  .work__entry {
    padding-block: var(--space-5);
    border-top: 1px solid var(--surface-2);
    scroll-margin-top: 4rem;
  }
  .work__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
  }
  @media (min-width: 768px) {
    .work__grid {
      grid-template-columns: minmax(0, 1fr) 120px;
      gap: var(--space-4);
      align-items: start;
    }
  }
  .work__main { min-width: 0; }
  .work__glyph {
    display: flex;
    justify-content: flex-start;
    padding: var(--space-2);
    border: 1px solid var(--surface-2);
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--surface-1) 50%, transparent);
  }
  @media (min-width: 768px) {
    .work__glyph { order: 2; align-self: start; position: sticky; top: 4.5rem; }
  }
  .work__header {
    margin-bottom: var(--space-3);
  }
  .work__title {
    font-family: var(--font-body);
    font-size: 1.5rem;
    font-weight: var(--fw-semibold);
    color: var(--ink);
    margin-bottom: var(--space-1);
  }
  .work__status {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    text-transform: uppercase;
    color: var(--ink-muted);
    margin: 0;
  }
  .work__tech {
    list-style: none;
    padding: 0;
    margin: var(--space-4) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    color: var(--ink-muted);
  }
  .work__tech li {
    padding: 2px var(--space-2);
    border: 1px solid var(--surface-2);
    border-radius: var(--radius-sm);
  }
</style>
