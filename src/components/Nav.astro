---
/**
 * Nav.astro — minimal text header.
 * Name on the left, four text links on the right, language toggle at the
 * far right. Zero JS. Keyboard-accessible via plain <a>.
 */
import { ui, localePrefix, type Locale } from '@/i18n/strings';
import LanguageSwitcher from '@/components/LanguageSwitcher.astro';

export interface Props {
  locale: Locale;
  pathKey: string;
}
const { locale, pathKey } = Astro.props;
const t = ui[locale];
const prefix = localePrefix(locale);

const workPath = locale === 'en' ? 'work/' : 'travaux/';
const researchPath = locale === 'en' ? 'research/' : 'recherche/';
const aboutPath = locale === 'en' ? 'about/' : 'a-propos/';

type Link = { key: string; href: string; label: string; match: string[] };

const links: Link[] = [
  { key: 'home',     href: prefix,                             label: t.navHome,     match: [''] },
  { key: 'work',     href: `${prefix}${workPath}`,             label: t.navWork,     match: [workPath] },
  { key: 'research', href: `${prefix}${researchPath}`,         label: t.navResearch, match: [researchPath] },
  { key: 'about',    href: `${prefix}${aboutPath}`,            label: t.navAbout,    match: [aboutPath] },
];
---

<nav class="primary-nav" aria-label={t.primaryNav}>
  <a class="primary-nav__brand" href={prefix} aria-label="Cyrille Tabe — home">
    cyrille tabe
  </a>

  <ul class="primary-nav__links">
    {links.slice(1).map((link) => {
      const isActive = link.match.includes(pathKey);
      return (
        <li>
          <a
            href={link.href}
            class={`primary-nav__link ${isActive ? 'is-active' : ''}`}
            aria-current={isActive ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      );
    })}
  </ul>

  <div class="primary-nav__tail">
    <LanguageSwitcher locale={locale} pathKey={pathKey} />
  </div>
</nav>

<style>
  .primary-nav {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding-inline: 1rem;
    max-width: 960px;
    margin-inline: auto;
    flex-wrap: wrap;
  }
  @media (min-width: 768px) { .primary-nav { padding-inline: 2rem; } }

  .primary-nav__brand {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--tr-mono);
    color: var(--ink);
    text-decoration: none;
    transition: color 120ms ease;
  }
  .primary-nav__brand:hover,
  .primary-nav__brand:focus-visible {
    color: var(--primary);
  }

  .primary-nav__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .primary-nav__link {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--tr-mono);
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 120ms ease;
  }
  .primary-nav__link:hover,
  .primary-nav__link:focus-visible {
    color: var(--ink);
  }
  .primary-nav__link.is-active {
    color: var(--primary);
  }

  .primary-nav__tail {
    margin-inline-start: auto;
  }

  @media (max-width: 480px) {
    .primary-nav__brand {
      /* Hide the name on very narrow screens to keep the links + lang
         toggle on a single row. */
      display: none;
    }
  }
</style>
