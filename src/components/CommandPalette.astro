---
/**
 * CommandPalette.astro — ⌘K / Ctrl+K global command palette.
 *
 * Vanilla JS + native <dialog>. Self-contained. Lazy HTML insertion —
 * the dialog body is rendered on first open. Localized labels are
 * injected via a `data-i18n` JSON blob so the script is locale-aware
 * without importing strings.ts at runtime.
 *
 * Keyboard:
 *  - ⌘K / Ctrl+K: toggle open.
 *  - Esc: close (native).
 *  - Arrow Up / Arrow Down: navigate.
 *  - Enter: activate.
 *  - Typing filters.
 */
import { ui, type Locale } from '@/i18n/strings';

export interface Props { locale: Locale }
const { locale } = Astro.props;
const t = ui[locale].cmdK;

const enPrefix = '/';
const frPrefix = '/fr/';
const otherLocale: Locale = locale === 'en' ? 'fr' : 'en';
const otherPrefix = otherLocale === 'en' ? enPrefix : frPrefix;

// Slug per-locale
const slug = (l: Locale) =>
  l === 'en'
    ? { work: 'work/', research: 'research/', about: 'about/' }
    : { work: 'travaux/', research: 'recherche/', about: 'a-propos/' };

const s = slug(locale);

type Action = {
  id: string;
  label: string;
  hint?: string;
  group: string;
  href?: string;
  external?: boolean;
  download?: boolean;
  kind?: 'link' | 'copy' | 'lang';
  target?: string;
};

const actions: Action[] = [
  { id: 'home',     label: t.navHome,     group: t.groupNav, href: `${enPrefix}`, target: locale === 'en' ? '/' : '/fr/' },
  { id: 'work',     label: t.navWork,     group: t.groupNav, href: `${locale === 'en' ? enPrefix : frPrefix}${s.work}` },
  { id: 'research', label: t.navResearch, group: t.groupNav, href: `${locale === 'en' ? enPrefix : frPrefix}${s.research}` },
  { id: 'about',    label: t.navAbout,    group: t.groupNav, href: `${locale === 'en' ? enPrefix : frPrefix}${s.about}` },

  { id: 'jump-robotclaw', label: t.jumpRobotClaw, group: t.groupJump, href: `${locale === 'en' ? enPrefix : frPrefix}${s.work}#robotclaw` },
  { id: 'jump-experience', label: t.jumpExperience, group: t.groupJump, href: `${locale === 'en' ? enPrefix : frPrefix}${s.about}#professional-experience` },
  { id: 'jump-research', label: t.jumpResearch, group: t.groupJump, href: `${locale === 'en' ? enPrefix : frPrefix}${s.research}` },
  { id: 'jump-skills', label: t.jumpSkills, group: t.groupJump, href: `${locale === 'en' ? enPrefix : frPrefix}${s.about}#skills` },
  { id: 'jump-contact', label: t.jumpContact, group: t.groupJump, href: `${locale === 'en' ? enPrefix : frPrefix}${s.about}` },

  { id: 'lang', kind: 'lang', label: locale === 'en' ? t.switchToFR : t.switchToEN, group: t.groupLang, href: otherPrefix },

  { id: 'copy-email', kind: 'copy', label: t.copyEmail, group: t.groupActions, target: 'cyrilletabepro@gmail.com' },
  { id: 'cv', label: t.downloadCV, group: t.groupActions, href: '/cv/cyrille-tabe-cv-en.pdf', download: true },
  { id: 'gh', label: t.openGitHub, group: t.groupActions, href: 'https://github.com/cytab', external: true },
  { id: 'in', label: t.openLinkedIn, group: t.groupActions, href: 'https://linkedin.com/in/cyrille-tabe', external: true },
];

const config = {
  actions,
  strings: {
    open: t.open,
    searchPlaceholder: t.searchPlaceholder,
    empty: t.empty,
    toastCopied: ui[locale].copy.toast,
    toastFailed: ui[locale].copy.failed,
  },
};
---

<button class="cmdk-trigger" type="button" aria-label={t.open} data-cmdk-trigger>
  <span class="cmdk-trigger__hint">{t.hint}</span>
  <kbd class="cmdk-trigger__key">⌘K</kbd>
</button>
<dialog class="cmdk" aria-labelledby="cmdk-title" data-cmdk></dialog>

<script is:inline type="application/json" data-cmdk-config set:html={JSON.stringify(config)} />

<script is:inline>
  (function () {
    var cfgEl = document.querySelector('[data-cmdk-config]');
    if (!cfgEl) return;
    var cfg = JSON.parse(cfgEl.textContent || '{}');
    var dlg = document.querySelector('[data-cmdk]');
    if (!dlg) return;
    var triggers = document.querySelectorAll('[data-cmdk-trigger]');
    var built = false;
    var items = [];
    var activeIdx = 0;

    function isMac() {
      return /mac|iphone|ipad|ipod/i.test(navigator.userAgent || '');
    }

    function build() {
      if (built) return;
      built = true;
      // Structure the dialog lazily
      var groups = {};
      cfg.actions.forEach(function (a) {
        (groups[a.group] = groups[a.group] || []).push(a);
      });
      var html = '';
      html += '<form method="dialog" class="cmdk__form" aria-label="Command palette">';
      html += '<div class="cmdk__searchbar">';
      html += '<svg class="cmdk__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m20 20-3-3"/></svg>';
      html += '<input type="text" class="cmdk__input" id="cmdk-input" placeholder="' + escapeAttr(cfg.strings.searchPlaceholder) + '" autocomplete="off" aria-controls="cmdk-list" />';
      html += '<kbd class="cmdk__esc">Esc</kbd>';
      html += '</div>';
      html += '<ul class="cmdk__list" id="cmdk-list" role="listbox" aria-label="' + escapeAttr(cfg.strings.open) + '">';
      Object.keys(groups).forEach(function (g) {
        html += '<li class="cmdk__group" role="presentation"><span class="cmdk__group-label">' + escapeHtml(g) + '</span></li>';
        groups[g].forEach(function (a) {
          html += '<li class="cmdk__item" role="option" data-id="' + escapeAttr(a.id) + '" tabindex="-1">';
          html += '<span class="cmdk__item-label">' + escapeHtml(a.label) + '</span>';
          html += '</li>';
        });
      });
      html += '<li class="cmdk__empty" hidden>' + escapeHtml(cfg.strings.empty) + '</li>';
      html += '</ul>';
      html += '</form>';
      html += '<h2 id="cmdk-title" class="sr-only">' + escapeHtml(cfg.strings.open) + '</h2>';
      dlg.innerHTML = html;

      items = Array.prototype.slice.call(dlg.querySelectorAll('.cmdk__item'));
      var input = dlg.querySelector('.cmdk__input');

      input.addEventListener('input', function () { filter(input.value); });
      input.addEventListener('keydown', function (e) {
        if (e.key === 'ArrowDown') { e.preventDefault(); move(1); }
        else if (e.key === 'ArrowUp') { e.preventDefault(); move(-1); }
        else if (e.key === 'Enter') {
          e.preventDefault();
          var visible = visibleItems();
          if (visible[activeIdx]) activate(visible[activeIdx]);
        }
      });

      dlg.addEventListener('click', function (e) {
        var t = e.target;
        while (t && t !== dlg && !t.classList.contains('cmdk__item')) t = t.parentNode;
        if (t && t.classList && t.classList.contains('cmdk__item')) {
          activate(t);
        } else if (e.target === dlg) {
          dlg.close();
        }
      });
    }

    function escapeAttr(s) { return String(s).replace(/[&<>"']/g, function (c) { return '&#' + c.charCodeAt(0) + ';'; }); }
    function escapeHtml(s) { return escapeAttr(s); }

    function visibleItems() {
      return items.filter(function (it) { return !it.hidden; });
    }

    function filter(q) {
      q = (q || '').toLowerCase().trim();
      items.forEach(function (it) {
        var lbl = (it.querySelector('.cmdk__item-label').textContent || '').toLowerCase();
        var match = !q || fuzzy(lbl, q);
        it.hidden = !match;
      });
      // Hide group labels with zero visible children
      var lists = dlg.querySelectorAll('.cmdk__group');
      lists.forEach(function (gl) {
        var next = gl.nextSibling;
        var count = 0;
        while (next && next.classList && next.classList.contains('cmdk__item')) {
          if (!next.hidden) count++;
          next = next.nextSibling;
        }
        gl.hidden = count === 0;
      });
      var empty = dlg.querySelector('.cmdk__empty');
      if (empty) empty.hidden = visibleItems().length > 0;
      activeIdx = 0;
      paint();
    }

    function fuzzy(text, q) {
      if (text.indexOf(q) !== -1) return true;
      // character-subsequence match
      var i = 0, j = 0;
      while (i < text.length && j < q.length) {
        if (text[i] === q[j]) j++;
        i++;
      }
      return j === q.length;
    }

    function move(dir) {
      var vis = visibleItems();
      if (!vis.length) return;
      activeIdx = (activeIdx + dir + vis.length) % vis.length;
      paint();
      vis[activeIdx].scrollIntoView({ block: 'nearest' });
    }

    function paint() {
      var vis = visibleItems();
      items.forEach(function (it) { it.classList.remove('is-active'); it.removeAttribute('aria-selected'); });
      if (vis[activeIdx]) {
        vis[activeIdx].classList.add('is-active');
        vis[activeIdx].setAttribute('aria-selected', 'true');
      }
    }

    function toast(msg) {
      var existing = document.querySelector('.cmdk-toast');
      if (existing) existing.remove();
      var t = document.createElement('div');
      t.className = 'cmdk-toast';
      t.setAttribute('role', 'status');
      t.setAttribute('aria-live', 'polite');
      t.textContent = msg;
      document.body.appendChild(t);
      requestAnimationFrame(function () { t.classList.add('is-visible'); });
      setTimeout(function () {
        t.classList.remove('is-visible');
        setTimeout(function () { t.remove(); }, 300);
      }, 1600);
    }

    function activate(itemEl) {
      var id = itemEl.getAttribute('data-id');
      var a = cfg.actions.find(function (x) { return x.id === id; });
      if (!a) return;
      dlg.close();
      if (a.kind === 'copy') {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(a.target || '').then(
            function () { toast(cfg.strings.toastCopied); },
            function () { toast(cfg.strings.toastFailed); }
          );
        } else {
          toast(cfg.strings.toastFailed);
        }
        return;
      }
      if (a.external) {
        window.open(a.href, '_blank', 'noopener');
        return;
      }
      if (a.download) {
        var link = document.createElement('a');
        link.href = a.href;
        link.download = '';
        document.body.appendChild(link);
        link.click();
        link.remove();
        return;
      }
      if (a.href) {
        window.location.href = a.href;
      }
    }

    function open() {
      build();
      if (!dlg.open) {
        try { dlg.showModal(); } catch (e) { dlg.setAttribute('open', ''); }
        var input = dlg.querySelector('.cmdk__input');
        if (input) { input.value = ''; filter(''); input.focus(); }
      }
    }

    document.addEventListener('keydown', function (e) {
      var mod = isMac() ? e.metaKey : e.ctrlKey;
      if (mod && (e.key === 'k' || e.key === 'K')) {
        // Still allow cmd+k in command palette input? Sure, to toggle close.
        e.preventDefault();
        if (dlg.open) dlg.close(); else open();
      }
    });

    triggers.forEach(function (b) {
      b.addEventListener('click', open);
    });
  })();
</script>

<style>
  .cmdk-trigger {
    display: none;
    align-items: center;
    gap: 0.35em;
    background: transparent;
    border: 1px solid var(--surface-2);
    border-radius: var(--radius-sm);
    color: var(--ink-muted);
    padding: 0.15em 0.4em;
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    cursor: pointer;
    transition: border-color 120ms ease, color 120ms ease;
  }
  .cmdk-trigger:hover,
  .cmdk-trigger:focus-visible {
    border-color: var(--primary);
    color: var(--ink);
  }
  .cmdk-trigger__key {
    font-family: var(--font-mono);
    color: var(--ink);
    background: var(--surface-2);
    padding: 0 0.3em;
    border-radius: 2px;
  }
  @media (hover: hover) and (min-width: 720px) {
    .cmdk-trigger { display: inline-flex; }
  }

  .cmdk {
    border: none;
    padding: 0;
    background: transparent;
    max-width: min(560px, 92vw);
    width: 100%;
    color: var(--ink);
    margin-top: 14vh;
    /* dialog centers itself horizontally by default */
  }
  .cmdk::backdrop {
    background: color-mix(in srgb, var(--bg) 70%, black);
    backdrop-filter: blur(4px);
  }
  .cmdk[open] {
    animation: cmdk-in 180ms var(--ease-default, cubic-bezier(0.22, 1, 0.36, 1));
  }
  @keyframes cmdk-in {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .cmdk__form {
    background: var(--surface-1);
    border: 1px solid var(--surface-2);
    border-radius: var(--radius-lg);
    box-shadow: 0 16px 48px -8px rgba(0,0,0,0.45);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: 62vh;
  }
  .cmdk__searchbar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3);
    border-bottom: 1px solid var(--surface-2);
  }
  .cmdk__icon { color: var(--ink-muted); flex: 0 0 auto; }
  .cmdk__input {
    flex: 1;
    background: transparent;
    border: 0;
    outline: none;
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.5;
    min-width: 0;
  }
  .cmdk__input::placeholder { color: var(--ink-muted); }
  .cmdk__esc {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    color: var(--ink-muted);
    background: var(--surface-2);
    padding: 0.15em 0.4em;
    border-radius: 2px;
  }
  .cmdk__list {
    list-style: none;
    margin: 0;
    padding: var(--space-2);
    overflow-y: auto;
    max-height: 52vh;
  }
  .cmdk__group {
    padding: var(--space-2) var(--space-2) var(--space-1);
  }
  .cmdk__group[hidden] { display: none; }
  .cmdk__group-label {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--tr-micro);
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .cmdk__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    cursor: pointer;
    color: var(--ink);
  }
  .cmdk__item[hidden] { display: none; }
  .cmdk__item.is-active {
    background: color-mix(in srgb, var(--primary) 12%, transparent);
    color: var(--ink);
    outline: 1px solid color-mix(in srgb, var(--primary) 35%, transparent);
  }
  .cmdk__item:hover {
    background: var(--surface-2);
  }
  .cmdk__item-label {
    font-size: 0.9375rem;
    line-height: 1.4;
  }
  .cmdk__empty {
    padding: var(--space-4);
    text-align: center;
    color: var(--ink-muted);
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
  }
  .cmdk__empty[hidden] { display: none; }
</style>
