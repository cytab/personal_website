---
/**
 * WorkGlyph.astro — per-project animated glyph. Pure SVG + CSS, no JS.
 * Each glyph is scoped, ≤ 1.5 KB gzip, and paused under
 * prefers-reduced-motion (via the global safety net in global.css).
 */
export interface Props {
  slug: 'robotclaw' | 'openclaw' | 'drone-stack' | 'noovelia-lattice' | 'odu-slam';
}
const { slug } = Astro.props;
---

<div class={`glyph glyph--${slug}`} aria-hidden="true">
  {slug === 'robotclaw' && (
    <svg viewBox="0 0 96 64" width="96" height="64" focusable="false" role="presentation">
      {/* Terminal panel with a blinking cursor and POMDP belief samples */}
      <rect x="1" y="1" width="94" height="62" fill="none" stroke="#1F2427" stroke-width="1"/>
      {/* Prompt "glyph" — a chevron, no letterforms */}
      <polyline points="6,14 11,18 6,22" fill="none" stroke="#8E8A82" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round"/>
      {/* Bar placeholder representing the prompt line */}
      <line x1="15" y1="19" x2="38" y2="19" stroke="#8E8A82" stroke-width="1.5"/>
      <rect x="42" y="13" width="5" height="9" fill="#F3A03B" class="cursor"/>
      {/* Particles: POMDP belief samples */}
      <circle cx="14" cy="40" r="1.5" fill="#62E0C8" class="p p1"/>
      <circle cx="24" cy="44" r="1.5" fill="#62E0C8" class="p p2"/>
      <circle cx="36" cy="38" r="1.5" fill="#62E0C8" class="p p3"/>
      <circle cx="52" cy="46" r="1.5" fill="#62E0C8" class="p p4"/>
      <circle cx="66" cy="40" r="1.5" fill="#62E0C8" class="p p5"/>
      <circle cx="78" cy="44" r="1.5" fill="#62E0C8" class="p p6"/>
    </svg>
  )}

  {slug === 'openclaw' && (
    <svg viewBox="0 0 96 64" width="96" height="64" focusable="false">
      {/* Four nodes with linked brightening */}
      <line x1="16" y1="32" x2="32" y2="32" stroke="#1F2427" class="link l1"/>
      <line x1="32" y1="32" x2="64" y2="32" stroke="#1F2427" class="link l2"/>
      <line x1="64" y1="32" x2="80" y2="32" stroke="#1F2427" class="link l3"/>
      <circle cx="16" cy="32" r="4" fill="#15191B" stroke="#8E8A82" class="nd n1"/>
      <circle cx="32" cy="32" r="4" fill="#15191B" stroke="#8E8A82" class="nd n2"/>
      <circle cx="64" cy="32" r="4" fill="#15191B" stroke="#8E8A82" class="nd n3"/>
      <circle cx="80" cy="32" r="4" fill="#15191B" stroke="#8E8A82" class="nd n4"/>
    </svg>
  )}

  {slug === 'drone-stack' && (
    <svg viewBox="0 0 96 64" width="96" height="64" focusable="false">
      {/* Top-down drone silhouette with four rotating rotor arcs */}
      <g transform="translate(48 32)">
        {/* Airframe arms (X layout) */}
        <line x1="-18" y1="-12" x2="18" y2="12" stroke="#8E8A82" stroke-width="1.25"/>
        <line x1="-18" y1="12" x2="18" y2="-12" stroke="#8E8A82" stroke-width="1.25"/>
        {/* Center body */}
        <rect x="-4" y="-4" width="8" height="8" fill="#15191B" stroke="#8E8A82" stroke-width="1"/>
        {/* Rotors — circles + rotating arc */}
        <g class="rotor">
          <circle cx="-18" cy="-12" r="7" fill="none" stroke="#1F2427"/>
          <circle cx="-18" cy="-12" r="6.5" fill="none" stroke="#F3A03B" stroke-width="1.5" stroke-dasharray="6 30" class="blade"/>
        </g>
        <g class="rotor r2">
          <circle cx="18" cy="-12" r="7" fill="none" stroke="#1F2427"/>
          <circle cx="18" cy="-12" r="6.5" fill="none" stroke="#F3A03B" stroke-width="1.5" stroke-dasharray="6 30" class="blade"/>
        </g>
        <g class="rotor r3">
          <circle cx="-18" cy="12" r="7" fill="none" stroke="#1F2427"/>
          <circle cx="-18" cy="12" r="6.5" fill="none" stroke="#F3A03B" stroke-width="1.5" stroke-dasharray="6 30" class="blade"/>
        </g>
        <g class="rotor r4">
          <circle cx="18" cy="12" r="7" fill="none" stroke="#1F2427"/>
          <circle cx="18" cy="12" r="6.5" fill="none" stroke="#F3A03B" stroke-width="1.5" stroke-dasharray="6 30" class="blade"/>
        </g>
      </g>
    </svg>
  )}

  {slug === 'noovelia-lattice' && (
    <svg viewBox="0 0 96 64" width="96" height="64" focusable="false">
      {/* 4x3 lattice grid; path drawn from start to goal */}
      <g>
        {Array.from({ length: 4 }).map((_, c) =>
          Array.from({ length: 3 }).map((_, r) => (
            <circle cx={12 + c * 24} cy={12 + r * 20} r="2" fill="#1F2427" stroke="#8E8A82" stroke-width="0.5"/>
          ))
        )}
        {/* Path trace */}
        <polyline
          points="12,52 36,52 36,32 60,32 60,12 84,12"
          fill="none"
          stroke="#F3A03B"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="path"
        />
        {/* Start / goal highlights */}
        <circle cx="12" cy="52" r="3" fill="#62E0C8" class="terminal"/>
        <circle cx="84" cy="12" r="3" fill="#F3A03B" class="terminal"/>
      </g>
    </svg>
  )}

  {slug === 'odu-slam' && (
    <svg viewBox="0 0 96 64" width="96" height="64" focusable="false">
      {/* 2-wheeled sidewalk robot + fading point cloud */}
      <g transform="translate(22 30)">
        {/* Body */}
        <rect x="-12" y="-10" width="24" height="16" fill="#15191B" stroke="#8E8A82" stroke-width="1"/>
        <rect x="-6" y="-14" width="12" height="5" fill="#15191B" stroke="#8E8A82" stroke-width="1"/>
        {/* Wheels */}
        <circle cx="-12" cy="8" r="4" fill="none" stroke="#8E8A82" stroke-width="1" class="wheel"/>
        <circle cx="12"  cy="8" r="4" fill="none" stroke="#8E8A82" stroke-width="1" class="wheel w2"/>
        <line x1="-12" y1="8" x2="-9" y2="8" stroke="#F3A03B" stroke-width="1.25" class="wheel-tick"/>
        <line x1="12" y1="8" x2="15" y2="8" stroke="#F3A03B" stroke-width="1.25" class="wheel-tick wt2"/>
      </g>
      {/* Point cloud */}
      <g class="cloud">
        <circle cx="54" cy="18" r="1" fill="#62E0C8" class="pt pt1"/>
        <circle cx="62" cy="24" r="1" fill="#62E0C8" class="pt pt2"/>
        <circle cx="72" cy="20" r="1" fill="#62E0C8" class="pt pt3"/>
        <circle cx="80" cy="28" r="1" fill="#62E0C8" class="pt pt4"/>
        <circle cx="58" cy="36" r="1" fill="#62E0C8" class="pt pt5"/>
        <circle cx="70" cy="42" r="1" fill="#62E0C8" class="pt pt6"/>
        <circle cx="82" cy="40" r="1" fill="#62E0C8" class="pt pt7"/>
        <circle cx="66" cy="48" r="1" fill="#62E0C8" class="pt pt8"/>
      </g>
    </svg>
  )}
</div>

<style>
  .glyph {
    display: inline-block;
    line-height: 0;
    flex: 0 0 auto;
  }
  .glyph svg {
    display: block;
  }

  /* robotclaw — cursor blink + particles */
  .glyph--robotclaw .cursor {
    animation: cursor-blink 1s steps(2) infinite;
  }
  @keyframes cursor-blink {
    0%, 50% { opacity: 1; }
    50.01%, 100% { opacity: 0; }
  }
  .glyph--robotclaw .p {
    animation: p-shift 3.2s infinite ease-in-out;
    opacity: 0.7;
  }
  .glyph--robotclaw .p1 { animation-delay: 0ms; }
  .glyph--robotclaw .p2 { animation-delay: 400ms; }
  .glyph--robotclaw .p3 { animation-delay: 200ms; }
  .glyph--robotclaw .p4 { animation-delay: 600ms; }
  .glyph--robotclaw .p5 { animation-delay: 800ms; }
  .glyph--robotclaw .p6 { animation-delay: 1000ms; }
  @keyframes p-shift {
    0%, 100% { transform: translateY(0); opacity: 0.6; }
    50%      { transform: translateY(-3px); opacity: 1; }
  }
  .glyph--robotclaw svg { overflow: visible; }

  /* openclaw — link brightening */
  .glyph--openclaw .link {
    stroke-width: 1.25;
    opacity: 0.5;
  }
  .glyph--openclaw .l1 { animation: link-bright 3s infinite; }
  .glyph--openclaw .l2 { animation: link-bright 3s infinite 1s; }
  .glyph--openclaw .l3 { animation: link-bright 3s infinite 2s; }
  @keyframes link-bright {
    0%, 80% { stroke: #1F2427; }
    40%     { stroke: #62E0C8; }
  }
  .glyph--openclaw .nd { stroke-width: 0.75; }
  .glyph--openclaw .n1 { animation: node-pulse 3s infinite; }
  .glyph--openclaw .n2 { animation: node-pulse 3s infinite 0.75s; }
  .glyph--openclaw .n3 { animation: node-pulse 3s infinite 1.5s; }
  .glyph--openclaw .n4 { animation: node-pulse 3s infinite 2.25s; }
  @keyframes node-pulse {
    0%, 100% { stroke: #8E8A82; }
    50%      { stroke: #62E0C8; }
  }

  /* drone-stack — rotating blade arcs */
  .glyph--drone-stack .blade {
    transform-origin: center;
    transform-box: fill-box;
    animation: blade-spin 0.9s infinite linear;
  }
  .glyph--drone-stack .rotor { transform-origin: center; transform-box: fill-box; }
  /* Each rotor animated separately — use inherited center via stroke-dashoffset cycle */
  @keyframes blade-spin {
    from { stroke-dashoffset: 0; }
    to   { stroke-dashoffset: -72; }
  }

  /* noovelia-lattice — path redraw */
  .glyph--noovelia-lattice .path {
    stroke-dasharray: 160;
    stroke-dashoffset: 160;
    animation: path-draw 4s infinite cubic-bezier(0.65, 0, 0.35, 1);
  }
  @keyframes path-draw {
    0%        { stroke-dashoffset: 160; }
    40%, 80%  { stroke-dashoffset: 0; }
    100%      { stroke-dashoffset: 160; }
  }
  .glyph--noovelia-lattice .terminal {
    animation: terminal-pulse 2.4s infinite ease-in-out;
  }
  @keyframes terminal-pulse {
    0%, 100% { opacity: 0.5; }
    50%      { opacity: 1; }
  }

  /* odu-slam — wheel tick rotate + point cloud fade-in */
  .glyph--odu-slam .wheel-tick {
    transform-origin: -12px 8px;
    transform-box: view-box;
    animation: wheel-spin 1.4s infinite linear;
  }
  .glyph--odu-slam .wt2 { transform-origin: 12px 8px; }
  @keyframes wheel-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  .glyph--odu-slam .pt {
    opacity: 0;
    animation: pt-fade 3.6s infinite ease-out;
  }
  .glyph--odu-slam .pt1 { animation-delay: 0ms; }
  .glyph--odu-slam .pt2 { animation-delay: 150ms; }
  .glyph--odu-slam .pt3 { animation-delay: 300ms; }
  .glyph--odu-slam .pt4 { animation-delay: 450ms; }
  .glyph--odu-slam .pt5 { animation-delay: 600ms; }
  .glyph--odu-slam .pt6 { animation-delay: 750ms; }
  .glyph--odu-slam .pt7 { animation-delay: 900ms; }
  .glyph--odu-slam .pt8 { animation-delay: 1050ms; }
  @keyframes pt-fade {
    0%, 10%   { opacity: 0; transform: scale(0.8); }
    40%       { opacity: 1; transform: scale(1); }
    80%, 100% { opacity: 0; }
  }
  .glyph--odu-slam .pt {
    transform-origin: center;
    transform-box: fill-box;
  }

  /* Reduced-motion: held poses for each glyph. */
  @media (prefers-reduced-motion: reduce) {
    .glyph * {
      animation: none !important;
      transition: none !important;
    }
    .glyph--robotclaw .cursor { opacity: 1; }
    .glyph--noovelia-lattice .path { stroke-dashoffset: 0; }
    .glyph--odu-slam .pt { opacity: 0.9; }
  }
</style>
