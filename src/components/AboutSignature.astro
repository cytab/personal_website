---
/**
 * AboutSignature.astro — a small articulated arm icon next to the
 * About page title. One joint idles (slow rotate). Pure SVG + CSS,
 * no JS. Decorative, aria-hidden.
 */
---

<svg
  class="about-sig"
  viewBox="0 0 80 80"
  width="64"
  height="64"
  aria-hidden="true"
  focusable="false"
>
  {/* Base plinth */}
  <ellipse cx="40" cy="72" rx="18" ry="3" fill="none" stroke="#8E8A82" stroke-width="1"/>
  <rect x="32" y="58" width="16" height="14" fill="#15191B" stroke="#8E8A82" stroke-width="1"/>

  {/* Shoulder + upper arm — this is the idle joint */}
  <g class="about-sig__shoulder" style="transform-origin: 40px 58px; transform-box: fill-box;">
    <rect x="36" y="34" width="8" height="24" fill="#15191B" stroke="#8E8A82" stroke-width="1"/>
    {/* Elbow */}
    <circle cx="40" cy="34" r="3" fill="#15191B" stroke="#8E8A82" stroke-width="1"/>
    {/* Forearm (fixed relative to shoulder for simplicity) */}
    <rect x="38" y="16" width="6" height="18" fill="#15191B" stroke="#8E8A82" stroke-width="1"/>
    {/* Wrist */}
    <rect x="36" y="12" width="10" height="5" fill="#15191B" stroke="#8E8A82" stroke-width="1"/>
    {/* LED */}
    <circle cx="41" cy="10" r="1.5" fill="#F3A03B" class="about-sig__led"/>
  </g>
</svg>

<style>
  .about-sig {
    display: inline-block;
    line-height: 0;
    flex: 0 0 auto;
  }
  .about-sig__shoulder {
    animation: sig-rot 6s infinite ease-in-out;
  }
  @keyframes sig-rot {
    0%, 100% { transform: rotate(-6deg); }
    50%      { transform: rotate(6deg); }
  }
  .about-sig__led {
    animation: sig-led 2.4s infinite ease-in-out;
  }
  @keyframes sig-led {
    0%, 100% { opacity: 0.35; }
    50%      { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .about-sig__shoulder { animation: none; transform: rotate(0deg); }
    .about-sig__led      { animation: none; opacity: 0.8; }
  }
</style>
