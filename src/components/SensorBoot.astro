---
/**
 * SensorBoot — three-stage wake-up overlay.
 * Runs once per session (sessionStorage flag). Reduced-motion skips
 * straight to Ready. Visual stand-in only — Agent 10 may reimplement
 * the pixel layer; the orchestration lives here.
 *
 * Total envelope: 1800ms (Agent 6 §2.1).
 */
import { ui, type Locale } from '@/i18n/strings';

export interface Props { locale: Locale }
const { locale } = Astro.props;
const t = ui[locale].sensorBoot;
---

<div
  id="sensor-boot"
  class="sensor-boot"
  role="status"
  aria-live="polite"
  data-stage="0"
  data-stage-1={t.stage1}
  data-stage-2={t.stage2}
  data-stage-3={t.stage3}
>
  <div class="sensor-boot__inner">
    <span class="sensor-boot__eyebrow t-micro">§ 00 / BOOTING PERCEPTION</span>
    <span class="sensor-boot__line" aria-hidden="true"></span>
    <span class="sensor-boot__status">{t.stage1}</span>
    <div class="sensor-boot__bars" aria-hidden="true">
      <span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span><span></span>
    </div>
  </div>
  <noscript>
    <style>#sensor-boot{display:none !important;}</style>
  </noscript>
</div>

<script is:inline>
  (function () {
    const KEY = 'ct-sensor-boot-v1';
    const el = document.getElementById('sensor-boot');
    if (!el) return;
    const statusEl = el.querySelector('.sensor-boot__status');
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const alreadyBooted = sessionStorage.getItem(KEY) === '1';

    if (alreadyBooted) {
      el.remove();
      return;
    }

    const s2 = el.getAttribute('data-stage-2');
    const s3 = el.getAttribute('data-stage-3');

    if (reduced) {
      if (statusEl) statusEl.textContent = s3;
      el.setAttribute('data-stage', '3');
      setTimeout(() => {
        el.classList.add('sensor-boot--done');
        sessionStorage.setItem(KEY, '1');
        setTimeout(() => el.remove(), 240);
      }, 240);
      return;
    }

    // 0 → 600ms stage 1
    el.setAttribute('data-stage', '1');
    setTimeout(() => {
      if (statusEl) statusEl.textContent = s2;
      el.setAttribute('data-stage', '2');
    }, 600);
    setTimeout(() => {
      if (statusEl) statusEl.textContent = s3;
      el.setAttribute('data-stage', '3');
    }, 1400);
    setTimeout(() => {
      el.classList.add('sensor-boot--done');
      sessionStorage.setItem(KEY, '1');
      setTimeout(() => el.remove(), 240);
    }, 1800);
  })();
</script>

<style>
  .sensor-boot {
    position: fixed;
    inset: 0;
    z-index: 900;
    display: grid;
    place-items: center;
    background: var(--bg);
    transition: opacity 240ms var(--ease-default);
  }
  .sensor-boot--done { opacity: 0; pointer-events: none; }

  .sensor-boot__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: flex-start;
    padding: var(--space-5);
    max-width: 480px;
  }
  .sensor-boot__line {
    display: block;
    width: 48px; height: 1px;
    background: var(--ink-muted);
    opacity: 0.4;
  }
  .sensor-boot__status {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    line-height: var(--lh-mono);
    letter-spacing: var(--tr-mono);
    color: var(--ink);
  }
  .sensor-boot__bars {
    display: flex;
    gap: 2px;
    height: 32px;
    align-items: flex-end;
    margin-top: var(--space-2);
  }
  .sensor-boot__bars > span {
    width: 4px;
    background: var(--ink-muted);
    height: 16px;
    transition: height 400ms var(--ease-system),
                background-color 400ms var(--ease-system);
  }
  /* Stage 1: near-uniform with slight variance */
  .sensor-boot[data-stage="1"] .sensor-boot__bars > span:nth-child(2n) { height: 12px; }
  .sensor-boot[data-stage="1"] .sensor-boot__bars > span:nth-child(3n) { height: 18px; }
  /* Stage 2: converging toward a peak (index 3) */
  .sensor-boot[data-stage="2"] .sensor-boot__bars > span:nth-child(4) {
    height: 32px; background: var(--primary);
  }
  .sensor-boot[data-stage="2"] .sensor-boot__bars > span:not(:nth-child(4)) {
    height: 8px;
  }
  /* Stage 3: locked */
  .sensor-boot[data-stage="3"] .sensor-boot__bars > span:nth-child(4) {
    height: 32px; background: var(--primary);
  }
  .sensor-boot[data-stage="3"] .sensor-boot__bars > span:not(:nth-child(4)) {
    height: 6px; opacity: 0.4;
  }
</style>
