---
/**
 * UncertaintyEllipse — SVG sigil per cluster.
 * Static skeleton only. TODO(agent-10): animate breath (±3% over
 * 1.6s per Agent 3 §4.3) inside a React island; ensure
 * reduced-motion renders at terminal locked state (phase-2-revisions
 * §3: "settled posterior").
 */

export type ClusterKey = 'perception' | 'planning' | 'human' | 'systems';

export interface Props {
  cluster: ClusterKey;
  size?: number;
  /** Decorative — adjacent heading carries meaning (Agent 8 §4.5). */
  ariaHidden?: boolean;
}

const { cluster, size = 96, ariaHidden = true } = Astro.props;

const shapes: Record<ClusterKey, { rx: number; ry: number; rotate: number; outerRing: boolean }> = {
  // Per Agent 3 §4.3
  perception: { rx: 26, ry: 24, rotate: 0, outerRing: false },     // tight, near-circular
  planning:   { rx: 30, ry: 14, rotate: 0, outerRing: true },       // eccentric, 2σ ring
  human:      { rx: 24, ry: 16, rotate: 30, outerRing: false },     // 30° tilt
  systems:    { rx: 22, ry: 20, rotate: 0, outerRing: false },      // compact on-axis
};

const s = shapes[cluster];
---

<svg
  class="u-ellipse"
  width={size}
  height={size}
  viewBox="0 0 64 64"
  aria-hidden={ariaHidden ? 'true' : undefined}
  role={ariaHidden ? undefined : 'img'}
>
  <g transform={`rotate(${s.rotate} 32 32)`}>
    {s.outerRing && (
      <ellipse
        cx="32" cy="32"
        rx={s.rx + 6} ry={s.ry + 6}
        fill="none" stroke="var(--ink-muted)" stroke-width="0.75"
        stroke-dasharray="2 3"
        opacity="0.6"
      />
    )}
    <ellipse
      cx="32" cy="32"
      rx={s.rx} ry={s.ry}
      fill="none" stroke="var(--ink)" stroke-width="1.25"
    />
    <circle cx="32" cy="32" r="1.5" fill="var(--primary)"/>
  </g>
</svg>

<style>
  .u-ellipse { display: inline-block; flex-shrink: 0; }
</style>
