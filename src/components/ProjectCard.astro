---
import UncertaintyEllipse, { type Props as EProps } from '@/components/UncertaintyEllipse.static.astro';

export interface Props {
  slug: string;
  title: string;
  body: string;
  cluster: EProps['cluster'];
  status?: string;
  repoUrl?: string;
  /** The /work/#anchor target for the card-as-link. */
  href: string;
}

const { slug, title, body, cluster, status, repoUrl, href } = Astro.props;
---

<article class="project-card" aria-labelledby={`card-${slug}-title`}>
  <a class="project-card__link" href={href} aria-labelledby={`card-${slug}-title`}>
    <header class="project-card__header">
      <UncertaintyEllipse cluster={cluster} size={32} />
      <h3 id={`card-${slug}-title`} class="project-card__title">{title}</h3>
      {status && <span class="project-card__status t-micro">{status}</span>}
    </header>
    <p class="project-card__body">{body}</p>
  </a>
  {repoUrl && (
    <a class="project-card__repo t-micro" href={repoUrl} rel="noopener">
      Open the repo →
    </a>
  )}
</article>

<style>
  .project-card {
    position: relative;
    background: var(--surface-1);
    border: 1px solid var(--surface-2);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition: background-color var(--dur-base) var(--ease-default),
                border-color var(--dur-base) var(--ease-default);
  }
  .project-card:hover, .project-card:focus-within {
    background: var(--surface-2);
    border-color: var(--primary);
  }
  .project-card__link {
    color: inherit;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .project-card__header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .project-card__title {
    font-size: var(--fs-h3);
    line-height: var(--lh-h3);
    font-weight: var(--fw-semibold);
    margin: 0;
    flex: 1;
  }
  .project-card__status {
    margin-inline-start: auto;
    padding: 2px var(--space-2);
    border: 1px solid var(--ink-muted);
    border-radius: var(--radius-sm);
  }
  .project-card__body {
    color: var(--ink);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    margin: 0;
  }
  .project-card__repo {
    color: var(--primary);
    text-decoration: none;
    align-self: flex-start;
  }
  .project-card__repo:hover,
  .project-card__repo:focus-visible {
    text-decoration: underline;
  }
</style>
