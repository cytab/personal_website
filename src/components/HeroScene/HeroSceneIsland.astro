---
/**
 * HeroSceneIsland.astro — wraps the R3F island so Astro can lazy-load it
 * with `client:visible`. Renders a static SSR fallback (an SVG preview of
 * the converged map) so reduced-motion and no-JS users see a sensible,
 * first-class frame — not a blank canvas.
 *
 * The fallback SVG is procedurally generated at build time from the same
 * Poisson sampler the WebGL scene uses (shared logic).
 */
import HeroScene from './index.tsx';
import { hashSeed, poissonDisk } from './poisson.ts';

export interface Props {
  seed?: string;
  locale?: 'en' | 'fr';
}
const { seed = 'home', locale = 'en' } = Astro.props;

// Static SVG is a single tuned frame of the converged map — acts as the
// SSR fallback and reduced-motion terminal state (both look similar
// because the reduced-motion design IS the converged frame).
const points = poissonDisk({
  seed: hashSeed(seed),
  minDist: 0.08,
  aspect: 0.6,
  maxPoints: 300,
});

// Pre-lock a handful of points (terminal loop-closures) for visual
// richness. Deterministic pairs based on index distance band.
let s = hashSeed(seed) | 1;
const rand = () => {
  s = (s * 1664525 + 1013904223) & 0xffffffff;
  return (s >>> 0) / 4294967296;
};
const lockedIdx = new Set<number>();
const arcs: Array<{ a: number; b: number }> = [];
for (let attempt = 0; attempt < 40 && arcs.length < 4; attempt++) {
  const a = Math.floor(rand() * points.length);
  const b = Math.floor(rand() * points.length);
  if (a === b || lockedIdx.has(a) || lockedIdx.has(b)) continue;
  const pa = points[a]!;
  const pb = points[b]!;
  const d = Math.hypot(pa.x - pb.x, pa.y - pb.y);
  if (d > 0.35 && d < 0.85) {
    arcs.push({ a, b });
    lockedIdx.add(a);
    lockedIdx.add(b);
  }
}

// Map NDC coords [-1, 1] × [-0.6, 0.6] onto SVG viewBox 1200 × 420.
const toX = (x: number) => ((x + 1) / 2) * 1200;
const toY = (y: number) => ((-y + 0.6) / 1.2) * 420;

const arcPaths = arcs.map(({ a, b }) => {
  const pa = points[a]!;
  const pb = points[b]!;
  const mx = (pa.x + pb.x) / 2;
  const my = (pa.y + pb.y) / 2;
  const dx = pb.x - pa.x;
  const dy = pb.y - pa.y;
  const dist = Math.hypot(dx, dy) || 1;
  const nx = -dy / dist;
  const ny = dx / dist;
  const bump = dist * 0.2;
  const cx = mx + nx * bump;
  const cy = my + ny * bump;
  return `M${toX(pa.x).toFixed(1)} ${toY(pa.y).toFixed(1)} Q${toX(cx).toFixed(1)} ${toY(cy).toFixed(1)} ${toX(pb.x).toFixed(1)} ${toY(pb.y).toFixed(1)}`;
});
---

<div class="hero-scene-wrap">
  <!-- SSR fallback + reduced-motion terminal state -->
  <svg
    class="hero-scene-fallback"
    viewBox="0 0 1200 420"
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
    focusable="false"
  >
    <defs>
      <pattern id={`lat-${seed}`} patternUnits="userSpaceOnUse" width="32" height="32">
        <path d="M 32 0 L 0 0 0 32" stroke="var(--ink-muted)" stroke-width="0.5" fill="none" opacity="0.25" />
      </pattern>
    </defs>
    <rect x="0" y="0" width="1200" height="420" fill={`url(#lat-${seed})`} />
    {points.map((p, i) => (
      <circle
        cx={toX(p.x).toFixed(1)}
        cy={toY(p.y).toFixed(1)}
        r={lockedIdx.has(i) ? 2.4 : 1.4}
        fill={lockedIdx.has(i) ? 'var(--primary)' : 'var(--ink)'}
        opacity={lockedIdx.has(i) ? 0.9 : 0.45}
      />
    ))}
    {arcPaths.map((d) => (
      <path d={d} fill="none" stroke="var(--primary)" stroke-width="1" opacity="0.55" />
    ))}
  </svg>

  <HeroScene client:visible seed={seed} locale={locale} />
</div>

<style>
  .hero-scene-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1200 / 420;
    min-height: 240px;
  }
  .hero-scene-fallback {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
  /* Once the WebGL canvas hydrates, it sits on top of the fallback.
     Under reduced-motion the canvas is transparent / frozen so the
     fallback keeps showing. */
  :global(.hero-scene) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }
  :global(.hero-scene__pause) {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--ink);
    background: color-mix(in srgb, var(--surface-1) 80%, transparent);
    border: 1px solid var(--surface-2);
    border-radius: var(--radius-md);
    cursor: pointer;
    z-index: 2;
    transition: background var(--dur-base) var(--ease-default);
  }
  :global(.hero-scene__pause:hover) {
    background: var(--surface-2);
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.hero-scene__pause) { display: none; }
  }
</style>
