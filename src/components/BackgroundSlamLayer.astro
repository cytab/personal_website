---
/**
 * BackgroundSlamLayer — ambient, very low-opacity SLAM drift behind
 * every page. Reuses the HeroScene React code via `skipBoot`.
 *
 * Rules (Agent 10 mandate F):
 *  - Opacity ≤ 0.08 (dark), ≤ 0.04 (light).
 *  - Off on mobile portrait (<640px width).
 *  - Off under prefers-reduced-motion.
 *  - Reuses the hero scene code path — no second canvas on the hero
 *    route (wrap caller omits this when on home).
 */
import HeroScene from './HeroScene/index.tsx';

export interface Props {
  seed?: string;
  locale?: 'en' | 'fr';
}
const { seed = 'background', locale = 'en' } = Astro.props;
---

<div class="bg-slam" aria-hidden="true">
  <HeroScene
    client:idle
    seed={seed}
    locale={locale}
    opacity={0.08}
    hidePauseControl={true}
    skipBoot={true}
  />
</div>

<style>
  .bg-slam {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .bg-slam :global(.hero-scene) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  /* Guard: disable on mobile portrait and under reduce. */
  @media (max-width: 640px) and (orientation: portrait),
         (prefers-reduced-motion: reduce) {
    .bg-slam { display: none; }
  }
  [data-theme="light"] .bg-slam :global(.hero-scene) {
    opacity: 0.5; /* darker ink point sprites on paper need a touch less */
  }
</style>
